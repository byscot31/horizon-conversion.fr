---
import { hashString, pickRotated } from "../../utils/seoLinks";

type Service = {
  slug: string;
  // selon tes pages/data : parfois name, parfois titre
  name?: string;
  titre?: string;

  // texte court (listing)
  description?: string;
  resume?: string;

  // uniques (si tu les ajoutes dans catalogue.ts)
  cas?: string;        // 1 phrase "cas typiques"
  qualifies?: string;  // 1 phrase "ce que tu qualifies"

  // icône (optionnelle pour éviter les crash/vides)
  icon?: string; // ex: "bi-tools" (ou autre)
};

type Ville = {
  slug: string;
  name?: string;
  nom?: string;
};

const {
  badge = "Services",
  title = "Services demandés",
  metierSlug,
  services = [],
  villes = [],
  villesCount = 3,
} = Astro.props;

const serviceUrl = (s: string) => `/metiers/${metierSlug}/services/${s}/`;
const villeUrl = (v: string) => `/metiers/${metierSlug}/villes/${v}/`;

const serviceTitle = (s: Service) => String(s.name ?? s.titre ?? "").trim();
const serviceDesc = (s: Service) => String(s.description ?? s.resume ?? "").trim();

const serviceCas = (s: Service) => String(s.cas ?? "").trim();
const serviceQualifies = (s: Service) => String(s.qualifies ?? "").trim();

const villeName = (v: Ville) => String(v.name ?? v.nom ?? "").trim();

const iconClass = (s: Service) => (s.icon && String(s.icon).trim().length ? String(s.icon).trim() : "bi-tools");
---

<div class="heading-block border-bottom-0 text-center">
  <div class="badge rounded-pill badge-default">{badge}</div>
  <h2 class="text-transform-none ls-0">{title}</h2>
</div>

<div class="clear"></div>

<div class="row mt-4 col-mb-50 mb-0">
  {services.map((s) => {
    const seed = hashString(`${metierSlug}:service:${s.slug}`);
    const villesForThisService = pickRotated(villes, seed, villesCount);

    const t = serviceTitle(s);
    const d = serviceDesc(s);
    const cas = serviceCas(s);
    const qual = serviceQualifies(s);

    return (
      <div class="col-sm-6 col-lg-4">
        <div class="feature-box">
          <div class="fbox-icon mb-4">
            <a href={serviceUrl(s.slug)} aria-label={t || "Service"}>
              <i class={`${iconClass(s)} text-white bg-color`}></i>
            </a>
          </div>

          <div class="fbox-content">
            <h3 class="text-transform-none">
              <a class="nav-link" href={serviceUrl(s.slug)}>{t}</a>
            </h3>

            <p class="mb-0">
              {d}

              {(cas || qual) && (
                <>
                  <br />
                  <small class="text-muted">
                    {cas && (
                      <>
                        <strong>Cas typiques :</strong> {cas}
                      </>
                    )}
                    {cas && qual ? " " : ""}
                    {qual && (
                      <>
                        <strong>Je qualifie :</strong> {qual}
                      </>
                    )}
                  </small>
                </>
              )}

              {villesForThisService.length > 0 && (
                <>
                  <br />
                  <small class="text-muted">
                    Villes :{" "}
                    {villesForThisService.map((v, idx) => (
                      <>
                        <a href={villeUrl(v.slug)}>{villeName(v)}</a>
                        {idx < villesForThisService.length - 1 ? " • " : ""}
                      </>
                    ))}
                  </small>
                </>
              )}
            </p>
          </div>
        </div>
      </div>
    );
  })}
</div>
