---
const {
  portalId = "147571896",
  formGuid = "37afaad1-d647-4342-9e90-76b00be43ed5",
  region = "eu1",
  submitLabel = "Demander un audit",
} = Astro.props;

if (!portalId || !formGuid) {
  console.warn("[HubspotFormCanvas] portalId / formGuid manquants.");
}
---

<div
  class="card shadow-sm"
  data-hs-portal-id={portalId}
  data-hs-form-guid={formGuid}
  data-hs-region={region}
>
  <div class="card-body">
    <h3 class="h4 mb-3">Demander un audit</h3>

    <div class="hc-form-widget">
      <div class="form-result" aria-live="polite" hidden></div>

      <form class="row mb-0 js-hs-custom-form" novalidate>
        <div class="row">

          <div class="col-md-6 form-group mb-3">
            <label for="hc-lastname">Nom *</label>
            <input type="text" id="hc-lastname" name="lastname" class="form-control input-sm" required />
          </div>

          <div class="col-md-6 form-group mb-3">
            <label for="hc-firstname">Prénom *</label>
            <input type="text" id="hc-firstname" name="firstname" class="form-control input-sm" required />
          </div>

          <div class="w-100"></div>

          <div class="col-6 form-group mb-3">
            <label for="hc-email">Email *</label>
            <input type="email" id="hc-email" name="email" class="form-control input-sm" required />
          </div>

          <div class="col-6 form-group mb-4">
            <label for="hc-phone">Téléphone *</label>
            <input type="tel" id="hc-phone" name="phone" class="form-control input-sm" required />
          </div>

          <div class="w-100"></div>

          <div class="col-md-6 form-group">
            <label for="hc-activite">Votre activité *</label>
            <select id="hc-activite" name="activite" class="form-select">
              <option value="">-- Sélectionnez --</option>
              <option value="Artisan">Artisan</option>
              <option value="TPE">TPE</option>
              <option value="PME">PME</option>
              <option value="Indépendant">Indépendant</option>
              <option value="Commerce">Commerce</option>
              <option value="Autre">Autre</option>
            </select>
          </div>

          <div class="col-6 form-group mb-4">
            <label for="hc-city">Zone / Ville *</label>
            <input type="text" id="hc-city" name="city" class="form-control input-sm" required />
          </div>

          <div class="w-100"></div>

          <div class="col-12 form-group">
            <label class="d-block" for="hc-message">Objectif principal *</label>
            <div class="form-check form-check-inline">
              <input class="form-check-input" type="checkbox" name="objectif_principal" value="Plus d’appels" id="hc-Check1">
              <label class="form-check-label" for="hc-Check1">
                Plus d’appels
              </label>
            </div>
            <div class="form-check form-check-inline">
              <input class="form-check-input" type="checkbox" name="objectif_principal" value="Plus de devis" id="hc-Check2">
              <label class="form-check-label" for="hc-Check2">
                Plus de devis
              </label>
            </div>
            <div class="form-check form-check-inline">
              <input class="form-check-input" type="checkbox" name="objectif_principal" value="Plus de trafic qualifié" id="hc-Check3">
              <label class="form-check-label" for="hc-Check3">
                Plus de trafic qualifié
              </label>
            </div>
            <div class="form-check form-check-inline">
              <input class="form-check-input" type="checkbox" name="objectif_principal" value="Améliorer site & conversion" id="hc-Check4">
              <label class="form-check-label" for="hc-Check4">
                Améliorer site & conversion
              </label>
            </div>
            <div class="form-check form-check-inline">
              <input class="form-check-input" type="checkbox" name="objectif_principal" value="Lancer une pub locale" id="hc-Check5">
              <label class="form-check-label" for="hc-Check5">
                Lancer une pub locale
              </label>
            </div>
          </div>

          <!-- honeypot anti-spam -->
          <div class="col-12 form-group d-none">
            <label for="hc-company">Company</label>
            <input type="text" id="hc-company" name="company_hp" class="form-control" tabindex="-1" autocomplete="off" />
          </div>

          <div class="col-12 form-group mb-0">
            <button class="button button-rounded w-100 text-transform-none ls-0 m-0 js-submit" type="submit">
              {submitLabel}
            </button>
          </div>
        </div>
      </form>

      <small class="d-block text-muted mt-3" style="line-height:1.35">
        Pas de spam. Juste un échange pour cadrer la zone et le besoin.
      </small>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    const SUBMIT_LABEL = "Demander un audit";

    function getCookie(name) {
      const m = document.cookie.match(new RegExp("(^| )" + name + "=([^;]+)"));
      return m ? decodeURIComponent(m[2]) : "";
    }

    function showResult(resultEl, html, type) {
      if (!resultEl) return;

      resultEl.innerHTML = html;

      // force l'affichage même si le thème cache .form-result
      resultEl.hidden = false;
      resultEl.style.display = "block";
      resultEl.classList.remove("d-none");

      // optionnel : petite ancre visuelle
      resultEl.setAttribute("data-status", type || "info");
      resultEl.scrollIntoView({ behavior: "smooth", block: "center" });
    }

    function mount() {
      document.querySelectorAll(".js-hs-custom-form").forEach((form) => {
        const card = form.closest("[data-hs-portal-id]");
        const portalId = card?.dataset.hsPortalId;
        const formGuid = card?.dataset.hsFormGuid;
        const region = card?.dataset.hsRegion || "eu1";

        if (!portalId || !formGuid) return;

        const resultEl = card.querySelector(".form-result");
        const btn = form.querySelector(".js-submit");
        const honeypot = form.querySelector("#hc-company");

        const base = region === "eu1" ? "https://api-eu1.hsforms.com" : "https://api.hsforms.com";
        const endpoint = `${base}/submissions/v3/integration/submit/${portalId}/${formGuid}`;

        if (form.dataset.bound === "1") return;
        form.dataset.bound = "1";

        const initialBtnText = btn?.textContent?.trim() || SUBMIT_LABEL;

        // CAPTURE + stopImmediatePropagation = évite qu’un JS du thème re-prenne la main
        form.addEventListener(
          "submit",
          async (e) => {
            e.preventDefault();
            e.stopImmediatePropagation();

            if (honeypot && honeypot.value.trim() !== "") return;

            if (!form.checkValidity()) {
              showResult(
                resultEl,
                `<div class="alert alert-danger mb-3">Merci de vérifier les champs obligatoires.</div>`,
                "error"
              );
              return;
            }

            if (btn) {
              btn.disabled = true;
              btn.textContent = "Envoi...";
            }
            if (resultEl) {
              resultEl.innerHTML = "";
              // au cas où le thème le cache
              resultEl.hidden = true;
              resultEl.style.display = "";
              resultEl.classList.remove("d-none");
            }

            const fd = new FormData(form);
            const fields = [];
            for (const [key, val] of fd.entries()) {
              const value = String(val ?? "").trim();
              if (!value) continue;
              if (key === "company_hp") continue; // ignore honeypot
              fields.push({ name: key, value });
            }

            const payload = {
              fields,
              context: {
                pageUri: window.location.href,
                pageName: document.title,
                hutk: getCookie("hubspotutk") || undefined,
              },
            };

            try {
              const res = await fetch(endpoint, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload),
              });

              if (!res.ok) throw new Error(await res.text());

              showResult(
                resultEl,
                `<div class="alert alert-success mb-3">Merci ! Je reviens vers vous rapidement.</div>`,
                "success"
              );
              form.reset();
            } catch (err) {
              console.warn("HubSpot submit error:", err);
              showResult(
                resultEl,
                `<div class="alert alert-danger mb-3">Oups… impossible d’envoyer pour le moment. Réessayez ou appelez-moi.</div>`,
                "error"
              );
            } finally {
              if (btn) {
                btn.disabled = false;
                btn.textContent = initialBtnText;
              }
            }
          },
          true
        );
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", mount, { once: true });
    } else {
      mount();
    }

    document.addEventListener("astro:page-load", mount);
  })();
</script>

