---
import Layout from "../../layouts/Layout.astro";
import HubspotForm from "../../components/HubspotForm.astro";
import { SITE } from "../../config/site";

const pageUrl = Astro.url.pathname;
const cityLabel = "Chantilly";
const zoneLabel = "Sud de l’Oise & Nord Val-d’Oise (95)";

const pageTitle = `Consultant webmarketing ${cityLabel} | SEO local + Devis premium + Site (conversion)`;
const description = `${cityLabel} : zone premium. SEO local + pages “confiance” (avis, preuves, réalisations) + parcours devis pour attirer des demandes qualifiées.`;

const nearby = [
  "Gouvieux","Lamorlaye","Coye-la-Forêt","Orry-la-Ville","La Chapelle-en-Serval","Plailly",
  "Senlis","Précy-sur-Oise","Saint-Leu-d’Esserent","Apremont","Vineuil-Saint-Firmin","Avilly-Saint-Léonard",
  "Pontarmé","Survilliers","Fosses","Creil","Nogent-sur-Oise","Montataire"
];

const quickFaqs = [
  {
    q: "Chantilly : pourquoi les clients sont plus exigeants ?",
    a: "Zone premium = attentes plus fortes (délais, finitions, clarté du devis). On met donc l’accent sur la <strong>confiance</strong> : preuves, méthode, réalisations, avis et un parcours devis fluide.",
  },
  {
    q: "Qu’est-ce qui convertit le mieux à Chantilly / Gouvieux ?",
    a: "Une page locale orientée <strong>rassurance</strong> : photos/réalisations, avis, process, et CTA “demande de devis” (pas un discours générique).",
  },
  {
    q: "Comment éviter les demandes “curieux / touristes” ?",
    a: "On cadre la zone + le type de demande (projet, budget, délai) avec 2–3 questions simples. Résultat : moins de temps perdu, plus de dossiers sérieux.",
  },
  {
    q: "SEO local ou pub locale à Chantilly ?",
    a: "Souvent <strong>SEO d’abord</strong> (durable) + pub en accélération ponctuelle (quand tu as de la dispo ou une offre précise). Dans les 2 cas, on filtre.",
  },
  {
    q: "Est-ce que je dois afficher un prix ?",
    a: "Pas forcément. Mais un <strong>cadre</strong> aide à filtrer (ex : “devis après visite”, “fourchette selon surface/complexité”). On choisit selon ton activité.",
  },
  {
    q: "Tu bosses avec artisans / TPE sur Chantilly et autour ?",
    a: "Oui. Sur Chantilly, on vise des demandes premium : rassurance + sélection (zone/besoin/délai) + suivi qualité.",
  },
];
---

<Layout title={pageTitle} description={description}>
  <!-- Page Title
  ============================================= -->
  <section
    class="page-title page-title-parallax parallax scroll-detect page-title-center dark include-header include-topbar"
    style="padding-bottom: 140px;"
  >
    <img
      src="/images/services/analysis-title.jpg"
      class="parallax-bg"
      alt="Chantilly : demandes premium et devis"
    />
    <div id="particles-line"></div>

    <div class="container position-relative">
      <div class="page-title-row">

        <div class="page-title-content">
          <div class="badge rounded-pill border border-light text-light">Zone : Chantilly & secteur premium</div>
          <h1>Chantilly : attirer des demandes premium (devis sérieux)</h1>
          <div class="mt-3">
            <small class="text-light op-08 d-block">
              Bassin premium : on travaille la confiance (preuves, avis, réalisations) + un parcours devis clair + filtrage anti hors-sujet.
            </small>
          </div>
        </div>

        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Accueil</a></li>
            <li class="breadcrumb-item"><a href="/seo-local-sud-oise-nord-95/">Sud Oise & Nord 95</a></li>
            <li class="breadcrumb-item active" aria-current="page">Chantilly</li>
          </ol>
        </nav>

      </div>
    </div>

    <div class="video-overlay z-1" style="background-image: linear-gradient(to top, rgba(254,150,3,0.5), #39384D);"></div>
  </section>

  <section id="content">
    <div class="content-wrap pb-0">

      <div class="container">

        <div class="row align-items-center">
          <div class="col-lg-7">
            <div class="badge rounded-pill badge-default">Chantilly</div>

            <h2 class="display-4 fw-bold">Une zone premium : la confiance fait la conversion.</h2>

            <p>
              Sur Chantilly / Gouvieux / Lamorlaye, les demandes sont souvent plus “projets” et plus exigeantes.
              Mon rôle : <strong>attirer des demandes premium</strong> (devis sérieux) en travaillant la <strong>rassurance</strong>
              et en <strong>filtrant</strong> le hors-sujet (zone, besoin, délai).
            </p>

            <p class="mb-4">
              Concrètement : on clarifie votre offre (prestations, niveau de gamme), votre rayon réel,
              puis on met en place des pages locales orientées confiance (avis, preuves, réalisations) + un parcours devis simple.
              Ensuite, on suit l’essentiel : <strong>appels</strong>, <strong>formulaires</strong> et <strong>qualité</strong>.
            </p>

            <div class="d-flex flex-wrap gap-2">
              <a href="/contact/" class="button button-rounded button-large text-transform-none ls-0">Demander un audit</a>
              <a
                href="/seo-local-sud-oise-nord-95/"
                class="button button-rounded button-large button-light text-dark bg-white border text-transform-none ls-0"
              >
                Voir les autres zones
              </a>
              <a
                href="/faqs/"
                class="button button-rounded button-large button-light text-dark bg-white border text-transform-none ls-0"
              >
                FAQ
              </a>
            </div>

            <small class="text-muted d-block mt-3">
              Astuce : sur Chantilly, on gagne souvent plus avec 1 page ultra crédible (preuves + méthode) qu’avec 10 pages “génériques”.
            </small>

            <div class="mt-3">
              <small class="text-muted">
                Communes proches : {nearby.slice(0, 10).join(" • ")}…
              </small>
            </div>
          </div>

          <div class="col-lg-5 mt-4 mt-lg-0 text-center">
            <img
              src="/images/services/analysis.svg"
              alt="Rassurance et demandes premium à Chantilly"
              style="max-width: 420px;"
              loading="lazy"
            />
          </div>
        </div>

        <div class="clear line my-6"></div>

        <div class="heading-block border-bottom-0 text-center">
          <div class="badge rounded-pill badge-default">Ce que je mets en place</div>
          <h2 class="text-transform-none ls-0">Pour Chantilly : confiance, tri, devis premium</h2>
          <p class="text-muted mb-0" style="max-width: 780px; margin: 0 auto;">
            Ici, l’objectif est d’obtenir des <strong>demandes premium</strong> :
            rassurer, cadrer, puis convertir en devis (pas du volume “brut”).
          </p>
        </div>

        <div class="clear"></div>

        <div class="row mt-4 col-mb-50 mb-0">

          <!-- 1 -->
          <div class="col-sm-6 col-lg-4">
            <div class="feature-box">
              <div class="fbox-icon mb-4">
                <a href="/seo-local-sud-oise-nord-95/chantilly/" aria-label="SEO local Chantilly">
                  <i class="fa-brands fa-google text-white bg-google"></i>
                </a>
              </div>
              <div class="fbox-content">
                <h3 class="text-transform-none">SEO local + Google (crédibilité)</h3>
                <p class="mb-0">
                  Page locale Chantilly orientée “confiance” : <strong>preuves</strong>, <strong>réalisations</strong>, <strong>avis</strong>,
                  zones servies et CTA “demander un devis”.
                </p>
                <small class="text-muted d-block mt-2">
                  Voir aussi : <a href="/seo-local-sud-oise-nord-95/">toutes les zones</a>
                </small>
              </div>
            </div>
          </div>

          <!-- 2 -->
          <div class="col-sm-6 col-lg-4">
            <div class="feature-box">
              <div class="fbox-icon mb-4">
                <a href="/faqs/" aria-label="Filtrage des demandes premium">
                  <i class="bi-funnel bg-dark border-0"></i>
                </a>
              </div>
              <div class="fbox-content">
                <h3 class="text-transform-none">Filtrage intelligent (premium)</h3>
                <p class="mb-0">
                  On filtre le hors-sujet : <strong>hors zone</strong>, demande trop floue, délai irréaliste.
                  Objectif : ne garder que des dossiers sérieux (devis / projets).
                </p>
                <small class="text-muted d-block mt-2">
                  À lire : <a href="/faqs/">cadrer sans faire fuir</a>
                </small>
              </div>
            </div>
          </div>

          <!-- 3 -->
          <div class="col-sm-6 col-lg-4">
            <div class="feature-box">
              <div class="fbox-icon mb-4">
                <a href="/contact/" aria-label="Conversion devis">
                  <i class="bi-telephone bg-info border-0"></i>
                </a>
              </div>
              <div class="fbox-content">
                <h3 class="text-transform-none">Parcours devis + suivi qualité</h3>
                <p class="mb-0">
                  CTA visibles, éléments de preuve, et un parcours devis clair.
                  Puis suivi simple : <strong>appels</strong>, <strong>formulaires</strong>, et qualité → ajustements.
                </p>
                <small class="text-muted d-block mt-2">
                  <a href="/contact/">Demander un audit</a> • réponse rapide (jours ouvrés)
                </small>
              </div>
            </div>
          </div>

        </div>

      </div>

      <div class="clear"></div>

      <!-- Zones autour / secteurs proches
      ============================================= -->
      <div class="section mb-0">
        <div class="container">
          <div class="heading-block border-bottom-0 text-center">
            <div class="badge rounded-pill badge-default">Zones autour</div>
            <h2 class="text-transform-none ls-0">Vous êtes proche de Chantilly ?</h2>
            <p class="text-muted mb-0" style="max-width: 820px; margin: 0 auto;">
              Choisissez la page la plus proche de votre secteur. Chaque bassin a son approche (volume, concurrence, type de demandes).
            </p>
          </div>

          <div class="row col-mb-30 align-content-stretch">

            <!-- 1 : Chantilly (page actuelle) -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/content_marketing.svg" alt="Chantilly" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">Chantilly</h3>
                      <p class="text-smaller mb-0">
                        Bassin premium : confiance + preuves + devis (filtrage anti hors-sujet).
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Chantilly • Gouvieux</li>
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Lamorlaye • Coye-la-Forêt</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : rassurance</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 2 : Senlis -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/experience.svg" alt="Senlis" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/senlis/">Senlis</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Zone “devis / projets” : moins de volume, plus de qualité (rassurance + process).
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Senlis • Chamant</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : mieux qualifié</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 3 : Creil / Saint-Maximin -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/analysis.svg" alt="Creil / Saint-Maximin" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/creil-saint-maximin/">Creil / Saint-Maximin</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Zone concurrentielle : volume + tri pour garder des demandes utiles (appels + devis).
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Creil • Saint-Maximin</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : volume + tri</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 4 : Nord 95 -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/adword.svg" alt="Nord 95" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/nord-95/">Nord 95</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Pour capter côté 95 : ciblage serré + exclusions pour garder la qualité.
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Persan • Beaumont • L’Isle-Adam</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : ciblage</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 5 : Nogent / Montataire -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/seo.svg" alt="Nogent / Montataire" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/nogent-montataire/">Nogent / Montataire</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Bassin “appels & devis” : idéal si tu veux du volume maîtrisé et utile.
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Nogent-sur-Oise • Montataire</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : demandes utiles</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 6 : Hub -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/adword.svg" alt="Sud Oise & Nord 95" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/">Sud Oise & Nord 95 (hub)</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Accès rapide à toutes les pages zones + explications simples (SEO local, pub locale, conversion).
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Choisir la zone la plus proche</li>
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Comprendre l’approche par bassin</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> <a href="/contact/">Demander un audit</a></li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

          </div>

        </div>
      </div>

      <!-- Form Section (Chantilly)
      ============================================= -->
      <div
        class="section mt-0"
        style="background: url('/images/sections/1.jpg') no-repeat center center; background-size: cover; padding: 100px 0;"
      >
        <div class="container">
          <div class="row justify-content-between align-items-center">

            <!-- Texte -->
            <div class="col-md-6">
              <div class="heading-block border-bottom-0 mb-4">
                <div class="badge rounded-pill badge-default">Audit rapide</div>
                <h2 class="text-transform-none ls-0">Chantilly : crédibilité + devis premium.</h2>
              </div>

              <p class="mb-3">
                En zone premium, le plus important c’est une demande <strong>qualifiée</strong> et un message <strong>crédible</strong> :
                zone OK, besoin clair, délai cohérent… et des preuves (avis, photos, réalisations).
              </p>

              <ul class="iconlist iconlist-color mb-4">
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Message</strong> : prestations + secteurs + positionnement</li>
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Preuves</strong> : avis / réalisations / process</li>
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Filtre</strong> : hors zone / hors budget / hors délai</li>
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Suivi</strong> : formulaires + appels + qualité</li>
              </ul>

              <div class="d-flex flex-wrap gap-2">
                <a href="/seo-local-sud-oise-nord-95/" class="button button-rounded button-light text-dark bg-white border text-transform-none ls-0">
                  Voir toutes les zones
                </a>
                <a href="/faqs/" class="button button-rounded button-light text-dark bg-white border text-transform-none ls-0">
                  FAQ (réponses simples)
                </a>
              </div>

              <small class="text-muted d-block mt-3">
                Besoin “devis/projets” ?{" "}
                <a href="/seo-local-sud-oise-nord-95/senlis/">Senlis</a>
                {" "}•{" "}
                Besoin volume + tri ?{" "}
                <a href="/seo-local-sud-oise-nord-95/creil-saint-maximin/">Creil / Saint-Maximin</a>
              </small>
            </div>

            <!-- Form HubSpot -->
            <div class="col-lg-4 col-md-5 mt-5 mt-md-0">
              <div class="card shadow-sm">
                <div class="card-body">
                  <h3 class="mb-2">Demander un audit</h3>
                  <p class="text-muted mb-3">Réponse rapide (jours ouvrés).</p>

                  <HubspotForm
                    context={{
                      page_type: "zone",
                      zone: "Chantilly",
                      area: "Sud Oise / Nord 95",
                      page_url: Astro.url.pathname,
                    }}
                  />

                  <small class="text-muted d-block mt-3">
                    Pas de spam. Un échange pour cadrer la zone + le type de demandes à viser.
                  </small>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>

      <!-- FAQ express -->
      <div class="section bg-transparent mt-0" style="background: url('/images/sections/3.jpg') no-repeat top center; background-size: cover; padding: 0 0 70px;">
        <div class="container">
          <div class="heading-block border-bottom-0 text-center">
            <div class="badge rounded-pill badge-default">FAQ express</div>
            <h2 class="text-transform-none ls-0">Questions fréquentes (Chantilly)</h2>
            <p class="text-muted mb-0">
              Zone premium : preuves + devis + filtrage pour garder des demandes sérieuses. Réponses courtes.
            </p>
          </div>

          <div class="row justify-content-center">
            <div class="col-lg-10">
              {quickFaqs.map((item) => (
                <div class="toggle faq pb-3 mb-4">
                  <div class="toggle-header">
                    <div class="toggle-icon color">
                      <i class="toggle-closed bi-question-circle"></i>
                      <i class="toggle-open bi-question-circle"></i>
                    </div>
                    <div class="toggle-title fw-semibold ps-1">{item.q}</div>
                    <div class="toggle-icon color">
                      <i class="toggle-closed fa-solid fa-chevron-down text-black-50"></i>
                      <i class="toggle-open fa-solid fa-chevron-up color"></i>
                    </div>
                  </div>

                  <div class="toggle-content text-black-50 ps-4">
                    {item.a}

                    <div class="mt-2">
                      <small class="text-muted">
                        Besoin d’une reco rapide ?{" "}
                        <a href="/contact/">Demander un audit</a>
                        {" "}•{" "}
                        <a href="/seo-local-sud-oise-nord-95/">Voir toutes les zones</a>
                        {" "}•{" "}
                        Zones proches :{" "}
                        <a href="/seo-local-sud-oise-nord-95/senlis/">Senlis</a>
                        {" "}•{" "}
                        <a href="/seo-local-sud-oise-nord-95/creil-saint-maximin/">Creil / Saint-Maximin</a>
                      </small>
                    </div>
                  </div>
                </div>
              ))}

              <div class="text-center d-flex flex-wrap justify-content-center gap-2">
                <a href="/faqs/" class="button button-rounded text-transform-none ls-0">Voir toutes les FAQ</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Promo/Contact (Chantilly)
      ============================================= -->
      <div
        class="section mt-5"
        style="padding: 100px 0; overflow: visible; background: url('/images/sections/3.jpg') no-repeat top center; background-size: cover;"
      >
        <div class="container">
          <div class="heading-block border-bottom-0 text-center">
            <div class="h5 text-uppercase ls-1 mb-2">Chantilly • Gouvieux • Lamorlaye</div>

            <h2 class="text-transform-none ls-0 mb-3">
              Vous voulez plus de <span>devis premium</span>…
              <br class="d-none d-md-block" />
              et moins de demandes “hors-sujet” ?
            </h2>

            <p class="text-muted mb-0" style="max-width: 820px; margin: 0 auto;">
              On fait un point rapide : zone réelle, prestations, niveau de gamme, et type de demandes à viser.
              Ensuite je te dis si le plus pertinent est <strong>SEO local</strong>, <strong>pub locale</strong>, ou un <strong>mix</strong>
              (avec filtrage + preuves).
            </p>

            <div class="d-flex flex-wrap justify-content-center gap-2 mt-4">
              <a href="/contact/" class="button button-large button-rounded text-transform-none ms-0 ls-0">
                Demander un audit
              </a>

