---
import Layout from "../../layouts/Layout.astro";
import HubspotForm from "../../components/HubspotForm.astro";
import { SITE } from "../../config/site";

const pageUrl = Astro.url.pathname;
const cityLabel = "Nord 95 (Persan / Beaumont / L’Isle-Adam)";
const zoneLabel = "Sud de l’Oise & Nord Val-d’Oise (95)";

const pageTitle = `Consultant webmarketing ${cityLabel} | SEO local + Pub locale + Site (conversion)`;
const description = `Nord 95 : visibilité locale sur Google + site clair + pub locale si besoin pour générer des demandes qualifiées (Persan, Beaumont, L’Isle-Adam).`;

const nearby = [
  "Persan","Beaumont-sur-Oise","L’Isle-Adam","Chambly","Méru","Bernes-sur-Oise","Bruyères-sur-Oise",
  "Champagne-sur-Oise","Nointel","Mours","Parmain","Valmondois","Auvers-sur-Oise","Butry-sur-Oise",
  "Fosses","Survilliers","Luzarches","Gouvieux","Chantilly","Le Mesnil-en-Thelle"
];

const quickFaqs = [
  {
    q: "Nord 95 : pourquoi c’est différent du Sud Oise ?",
    a: "Parce que la demande est souvent plus “multi-villes”. La clé, c’est un <strong>ciblage serré</strong> + des exclusions pour éviter le hors-zone (et du trafic inutile).",
  },
  {
    q: "Je reçois des demandes de trop loin (95/60/77…), tu peux filtrer ?",
    a: "Oui : on verrouille la zone (villes + rayon), on écrit clairement les secteurs servis, et en pub on exclut les zones trop loin. Résultat : moins de perte de temps.",
  },
  {
    q: "SEO local ou pub locale sur Persan / Beaumont ?",
    a: "Souvent un mix : <strong>pub</strong> pour démarrer vite, <strong>SEO</strong> pour construire du durable. On règle le volume selon ta capacité (plein = on baisse).",
  },
  {
    q: "Comment éviter les clics “curieux” ?",
    a: "Pages plus claires (prestations, secteurs, attentes) + formulaire cadré (ville, délai, type de demande) + mots-clés et exclusions côté pub.",
  },
  {
    q: "Combien de temps avant de voir des résultats ?",
    a: "La pub peut démarrer vite. Le SEO met plus de temps mais dure. Dans tous les cas, on commence par un parcours simple qui convertit.",
  },
  {
    q: "Tu interviens uniquement sur le 95 ?",
    a: "Non : on peut viser 95 + Sud Oise si c’est cohérent. L’idée : une zone réaliste, puis on étend si besoin.",
  },
];
---

<Layout title={pageTitle} description={description}>
  <!-- Page Title
  ============================================= -->
  <section
    class="page-title page-title-parallax parallax scroll-detect page-title-center dark include-header include-topbar"
    style="padding-bottom: 140px;"
  >
    <img
      src="/images/services/analysis-title.jpg"
      class="parallax-bg"
      alt="Nord 95 : Persan, Beaumont, L’Isle-Adam"
    />
    <div id="particles-line"></div>

    <div class="container position-relative">
      <div class="page-title-row">

        <div class="page-title-content">
          <div class="badge rounded-pill border border-light text-light">Zone : Nord Val-d’Oise (95)</div>
          <h1>Nord 95 : capter des demandes utiles (sans hors-zone)</h1>
          <div class="mt-3">
            <small class="text-light op-08 d-block">
              Persan • Beaumont • L’Isle-Adam : on verrouille le ciblage (villes/rayon + exclusions) pour garder des appels et devis exploitables.
            </small>
          </div>
        </div>

        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Accueil</a></li>
            <li class="breadcrumb-item"><a href="/seo-local-sud-oise-nord-95/">Sud Oise & Nord 95</a></li>
            <li class="breadcrumb-item active" aria-current="page">Nord 95</li>
          </ol>
        </nav>

      </div>
    </div>

    <div class="video-overlay z-1" style="background-image: linear-gradient(to top, rgba(254,150,3,0.5), #39384D);"></div>
  </section>

  <section id="content">
    <div class="content-wrap pb-0">

      <div class="container">

        <div class="row align-items-center">
          <div class="col-lg-7">
            <div class="badge rounded-pill badge-default">{cityLabel}</div>

            <h2 class="display-4 fw-bold">Du volume oui… mais on garde seulement l’utile.</h2>

            <p>
              Sur le Nord 95, les demandes peuvent vite partir “dans tous les sens” (villes multiples, zones limitrophes, hors-secteur).
              Mon rôle : <strong>capter des appels + demandes de devis</strong> et <strong>filtrer</strong> pour éviter le temps perdu.
            </p>

            <p class="mb-4">
              Concrètement : on clarifie votre <strong>rayon réel</strong> (villes / distance), vos prestations et vos priorités,
              puis on met en place des pages locales + (si besoin) une pub locale avec des <strong>exclusions</strong>.
              Ensuite, on suit l’essentiel : <strong>appels</strong>, <strong>formulaires</strong> et <strong>qualité des demandes</strong>.
            </p>

            <div class="d-flex flex-wrap gap-2">
              <a href="/contact/" class="button button-rounded button-large text-transform-none ls-0">Demander un audit</a>
              <a
                href="/seo-local-sud-oise-nord-95/"
                class="button button-rounded button-large button-light text-dark bg-white border text-transform-none ls-0"
              >
                Voir les autres zones
              </a>
              <a
                href="/faqs/"
                class="button button-rounded button-large button-light text-dark bg-white border text-transform-none ls-0"
              >
                FAQ
              </a>
            </div>

            <small class="text-muted d-block mt-3">
              Astuce : Nord 95 = <strong>ciblage + exclusions</strong> (sinon tu payes/convertis du hors-zone).
            </small>

            <div class="mt-3">
              <small class="text-muted">
                Communes proches : {nearby.slice(0, 10).join(" • ")}…
              </small>
            </div>
          </div>

          <div class="col-lg-5 mt-4 mt-lg-0 text-center">
            <img
              src="/images/services/analysis.svg"
              alt="Ciblage et filtrage Nord 95"
              style="max-width: 420px;"
              loading="lazy"
            />
          </div>
        </div>

        <div class="clear line my-6"></div>

        <div class="heading-block border-bottom-0 text-center">
          <div class="badge rounded-pill badge-default">Ce que je mets en place</div>
          <h2 class="text-transform-none ls-0">Pour Nord 95 : ciblage, exclusions, conversion</h2>
          <p class="text-muted mb-0" style="max-width: 780px; margin: 0 auto;">
            Ici, l’enjeu n’est pas “d’avoir des clics”, mais des <strong>demandes qualifiées</strong> :
            bonne zone, bon besoin, bon délai.
          </p>
        </div>

        <div class="clear"></div>

        <div class="row mt-4 col-mb-50 mb-0">

          <!-- 1 -->
          <div class="col-sm-6 col-lg-4">
            <div class="feature-box">
              <div class="fbox-icon mb-4">
                <a href="/seo-local-sud-oise-nord-95/nord-95/" aria-label="SEO local Nord 95">
                  <i class="fa-brands fa-google text-white bg-google"></i>
                </a>
              </div>
              <div class="fbox-content">
                <h3 class="text-transform-none">Pages locales + Google (SEO local)</h3>
                <p class="mb-0">
                  Pages claires : <strong>secteurs</strong>, <strong>prestations</strong>, preuves et CTA visibles
                  pour déclencher des <strong>appels</strong> et <strong>devis</strong>.
                </p>
                <small class="text-muted d-block mt-2">
                  Voir aussi : <a href="/seo-local-sud-oise-nord-95/">toutes les zones</a>
                </small>
              </div>
            </div>
          </div>

          <!-- 2 -->
          <div class="col-sm-6 col-lg-4">
            <div class="feature-box">
              <div class="fbox-icon mb-4">
                <a href="/faqs/" aria-label="Filtrage et exclusions">
                  <i class="bi-funnel bg-dark border-0"></i>
                </a>
              </div>
              <div class="fbox-content">
                <h3 class="text-transform-none">Filtrage + exclusions (anti hors-zone)</h3>
                <p class="mb-0">
                  On filtre le hors-sujet : <strong>hors zone</strong>, <strong>hors prestation</strong>,
                  délais irréalistes. Et en pub : <strong>exclusions</strong> pour éviter de payer le mauvais trafic.
                </p>
                <small class="text-muted d-block mt-2">
                  À lire : <a href="/faqs/">“demande qualifiée” : critères simples</a>
                </small>
              </div>
            </div>
          </div>

          <!-- 3 -->
          <div class="col-sm-6 col-lg-4">
            <div class="feature-box">
              <div class="fbox-icon mb-4">
                <a href="/contact/" aria-label="Suivi des appels et formulaires">
                  <i class="bi-telephone bg-info border-0"></i>
                </a>
              </div>
              <div class="fbox-content">
                <h3 class="text-transform-none">Suivi simple (appels + formulaires)</h3>
                <p class="mb-0">
                  On suit l’essentiel : <strong>appels</strong>, <strong>formulaires</strong>, qualité.
                  Si tu es plein : on baisse. Si tu as de la place : on relance.
                </p>
                <small class="text-muted d-block mt-2">
                  <a href="/contact/">Demander un audit</a> • réponse rapide (jours ouvrés)
                </small>
              </div>
            </div>
          </div>

        </div>

      </div>

      <div class="clear"></div>

      <!-- Zones autour / secteurs proches
      ============================================= -->
      <div class="section mb-0">
        <div class="container">
          <div class="heading-block border-bottom-0 text-center">
            <div class="badge rounded-pill badge-default">Zones autour</div>
            <h2 class="text-transform-none ls-0">Vous êtes proche de Persan / Beaumont / L’Isle-Adam ?</h2>
            <p class="text-muted mb-0" style="max-width: 820px; margin: 0 auto;">
              Choisissez la page la plus proche de votre secteur. Chaque bassin a son approche (volume, concurrence, type de demandes).
            </p>
          </div>

          <div class="row col-mb-30 align-content-stretch">

            <!-- 1 : Nord 95 (page actuelle) -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/adword.svg" alt="Nord 95" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">Nord 95</h3>
                      <p class="text-smaller mb-0">
                        Ciblage serré + exclusions : on garde des demandes utiles (appels/devis) sans payer le hors-zone.
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Persan • Beaumont-sur-Oise</li>
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> L’Isle-Adam • Parmain</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : ciblage + exclusions</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 2 : Chambly -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/seo.svg" alt="Chambly" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/chambly/">Chambly</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Connexion Oise/95 : demandes locales maîtrisées + filtre (rayon réaliste).
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Chambly • Bornel</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : demandes locales</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 3 : Chantilly -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/content_marketing.svg" alt="Chantilly" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/chantilly/">Chantilly</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Bassin premium : confiance + preuves + devis (filtrage anti hors-sujet).
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Chantilly • Gouvieux</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : rassurance</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 4 : Le Mesnil-en-Thelle -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/optimizing.svg" alt="Le Mesnil-en-Thelle" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/le-mesnil-en-thelle/">Le Mesnil-en-Thelle</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Proximité : demandes locales (rayon clair) + conversion simple (appels/devis).
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Le Mesnil-en-Thelle • Cires-lès-Mello</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : proximité</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 5 : Méru -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/optimizing.svg" alt="Méru" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/meru/">Méru</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Zone étendue : on cadre le rayon et on filtre fort pour éviter les demandes trop loin.
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Méru • Andeville</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : SEO + tri</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 6 : Hub -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/adword.svg" alt="Sud Oise & Nord 95" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/">Sud Oise & Nord 95 (hub)</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Accès rapide à toutes les pages zones + explications simples (SEO local, pub locale, conversion).
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Choisir la zone la plus proche</li>
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Comprendre l’approche par bassin</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> <a href="/contact/">Demander un audit</a></li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

          </div>

        </div>
      </div>

      <!-- Form Section (Nord 95)
      ============================================= -->
      <div
        class="section mt-0"
        style="background: url('/images/sections/1.jpg') no-repeat center center; background-size: cover; padding: 100px 0;"
      >
        <div class="container">
          <div class="row justify-content-between align-items-center">

            <!-- Texte -->
            <div class="col-md-6">
              <div class="heading-block border-bottom-0 mb-4">
                <div class="badge rounded-pill badge-default">Audit rapide</div>
                <h2 class="text-transform-none ls-0">Nord 95 : cadrer la zone et filtrer.</h2>
              </div>

              <p class="mb-3">
                Dans un secteur multi-villes, le plus important c’est de recevoir des demandes <strong>exploitables</strong> :
                <strong>bonne zone</strong>, <strong>bonne prestation</strong>, <strong>délai réaliste</strong>, contact joignable.
              </p>

              <ul class="iconlist iconlist-color mb-4">
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Zone</strong> : villes / rayon que vous traitez vraiment</li>
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Exclusions</strong> : on coupe les zones trop loin (pub)</li>
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Filtre</strong> : hors zone / hors budget / hors délai</li>
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Suivi</strong> : simple (on garde ce qui marche)</li>
              </ul>

              <div class="d-flex flex-wrap gap-2">
                <a href="/seo-local-sud-oise-nord-95/" class="button button-rounded button-light text-dark bg-white border text-transform-none ls-0">
                  Voir toutes les zones
                </a>
                <a href="/faqs/" class="button button-rounded button-light text-dark bg-white border text-transform-none ls-0">
                  FAQ (réponses simples)
                </a>
              </div>

              <small class="text-muted d-block mt-3">
                Vous êtes plutôt Chantilly (premium) ?{" "}
                <a href="/seo-local-sud-oise-nord-95/chantilly/">Voir la page</a>
                {" "}•{" "}
                Besoin volume + tri ?{" "}
                <a href="/seo-local-sud-oise-nord-95/creil-saint-maximin/">Creil / Saint-Maximin</a>
              </small>
            </div>

            <!-- Form HubSpot -->
            <div class="col-lg-4 col-md-5 mt-5 mt-md-0">
              <div class="card shadow-sm">
                <div class="card-body">
                  <h3 class="mb-2">Demander un audit</h3>
                  <p class="text-muted mb-3">Réponse rapide (jours ouvrés).</p>

                  <HubspotForm
                    context={{
                      page_type: "zone",
                      zone: "Nord 95",
                      area: "Sud Oise / Nord 95",
                      page_url: Astro.url.pathname,
                    }}
                  />

                  <small class="text-muted d-block mt-3">
                    Pas de spam. Un échange pour cadrer la zone + le type de demandes à viser.
                  </small>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>

      <!-- FAQ express -->
      <div class="section bg-transparent mt-0" style="background: url('/images/sections/3.jpg') no-repeat top center; background-size: cover; padding: 0 0 70px;">
        <div class="container">
          <div class="heading-block border-bottom-0 text-center">
            <div class="badge rounded-pill badge-default">FAQ express</div>
            <h2 class="text-transform-none ls-0">Questions fréquentes (Nord 95)</h2>
            <p class="text-muted mb-0">
              Persan • Beaumont • L’Isle-Adam : ciblage + exclusions pour éviter le hors-zone. Réponses courtes.
            </p>
          </div>

          <div class="row justify-content-center">
            <div class="col-lg-10">
              {quickFaqs.map((item) => (
                <div class="toggle faq pb-3 mb-4">
                  <div class="toggle-header">
                    <div class="toggle-icon color">
                      <i class="toggle-closed bi-question-circle"></i>
                      <i class="toggle-open bi-question-circle"></i>
                    </div>
                    <div class="toggle-title fw-semibold ps-1">{item.q}</div>
                    <div class="toggle-icon color">
                      <i class="toggle-closed fa-solid fa-chevron-down text-black-50"></i>
                      <i class="toggle-open fa-solid fa-chevron-up color"></i>
                    </div>
                  </div>

                  <div class="toggle-content text-black-50 ps-4">
                    {item.a}

                    <div class="mt-2">
                      <small class="text-muted">
                        Besoin d’une reco rapide ?{" "}
                        <a href="/contact/">Demander un audit</a>
                        {" "}•{" "}
                        <a href="/seo-local-sud-oise-nord-95/">Voir toutes les zones</a>
                        {" "}•{" "}
                        Zones proches :{" "}
                        <a href="/seo-local-sud-oise-nord-95/chambly/">Chambly</a>
                        {" "}•{" "}
                        <a href="/seo-local-sud-oise-nord-95/chantilly/">Chantilly</a>
                      </small>
                    </div>
                  </div>
                </div>
              ))}

              <div class="text-center d-flex flex-wrap justify-content-center gap-2">
                <a href="/faqs/" class="button button-rounded text-transform-none ls-0">Voir toutes les FAQ</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Promo/Contact (Nord 95)
      ============================================= -->
      <div
        class="section mt-5"
        style="padding: 100px 0; overflow: visible; background: url('/images/sections/3.jpg') no-repeat top center; background-size: cover;"
      >
        <div class="container">
          <div class="heading-block border-bottom-0 text-center">
            <div class="h5 text-uppercase ls-1 mb-2">Persan • Beaumont • L’Isle-Adam</div>

            <h2 class="text-transform-none ls-0 mb-3">
              Vous voulez plus <span>d’appels</span> et de <span>demandes de devis</span>…
              <br class="d-none d-md-block" />
              sans payer le mauvais trafic ?
            </h2>

            <p class="text-muted mb-0" style="max-width: 820px; margin: 0 auto;">
              On fait un point rapide : votre zone réelle, vos prestations, et le type de demandes à viser.
              Ensuite je te dis si le plus pertinent est <strong>SEO local</strong>, <strong>pub locale</strong>, ou un <strong>mix</strong>
              (avec exclusions + filtrage).
            </p>

            <div class="d-flex flex-wrap justify-content-center gap-2 mt-4">
