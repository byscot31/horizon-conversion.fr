---
import Layout from "../../layouts/Layout.astro";
import HubspotForm from "../../components/HubspotForm.astro";
import { SITE } from "../../config/site";

const pageUrl = Astro.url.pathname;
const cityLabel = "Senlis";
const zoneLabel = "Sud de l’Oise & Nord Val-d’Oise (95)";

const pageTitle = `Consultant webmarketing ${cityLabel} | SEO local + Devis + Site (conversion)`;
const description = `${cityLabel} : moins de volume, plus de qualité. SEO local + site clair + parcours devis pour générer des demandes premium (filtrage + rassurance).`;

const nearby = [
  "Chamant","Aumont-en-Halatte","Mont-l’Évêque","Barbery","Pontarmé","Orry-la-Ville",
  "Chantilly","Gouvieux","La Chapelle-en-Serval","Plailly","Survilliers","Fosses",
  "Verneuil-en-Halatte","Creil","Pont-Sainte-Maxence","Coye-la-Forêt","Lamorlaye","Nanteuil-le-Haudouin"
];

const quickFaqs = [
  {
    q: "Senlis : pourquoi j’ai moins d’appels mais des demandes “plus sérieuses” ?",
    a: "Senlis est souvent plus orientée <strong>projets / devis</strong> que dépannage. On optimise le parcours “demande de devis” (preuves + process + CTA) plutôt que de chercher du volume à tout prix.",
  },
  {
    q: "SEO local à Senlis : sur quoi on gagne vraiment ?",
    a: "Sur la <strong>qualité</strong> : page locale très spécifique, preuves (réalisations/avis), et un message clair (prestations + zones). L’objectif : convertir des demandes traitables, pas des clics.",
  },
  {
    q: "Comment filtrer sans faire fuir les bons clients ?",
    a: "Avec un formulaire court mais cadré (ville, type de besoin, délai, budget indicatif si utile) + une micro-copy rassurante. On filtre le hors sujet sans braquer.",
  },
  {
    q: "Pub locale à Senlis : utile ou pas ?",
    a: "Souvent <strong>ponctuellement</strong> (quand tu as de la place) ou sur une offre précise. Sinon, le SEO + la conversion suffisent pour viser des demandes premium.",
  },
  {
    q: "Combien de temps avant de voir des résultats ?",
    a: "La pub peut démarrer vite. Le SEO met plus de temps mais dure. Dans tous les cas, on commence par un parcours simple : page claire + CTA + preuves + contact.",
  },
  {
    q: "Tu bosses avec artisans / TPE sur Senlis et autour ?",
    a: "Oui. Sur Senlis, on fait souvent plus de <strong>rassurance</strong> (preuves, méthode, délais) et moins de “volume brut”.",
  },
];
---

<Layout title={pageTitle} description={description}>
  <!-- Page Title
  ============================================= -->
  <section
    class="page-title page-title-parallax parallax scroll-detect page-title-center dark include-header include-topbar"
    style="padding-bottom: 140px;"
  >
    <img
      src="/images/services/analysis-title.jpg"
      class="parallax-bg"
      alt="Senlis : demandes de devis et projets"
    />
    <div id="particles-line"></div>

    <div class="container position-relative">
      <div class="page-title-row">

        <div class="page-title-content">
          <div class="badge rounded-pill border border-light text-light">Zone : Senlis & alentours</div>
          <h1>Senlis : moins de volume, plus de demandes qualifiées</h1>
          <div class="mt-3">
            <small class="text-light op-08 d-block">
              Bassin “devis / projets” : on travaille la rassurance (preuves + process) et le filtrage pour garder des demandes premium.
            </small>
          </div>
        </div>

        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Accueil</a></li>
            <li class="breadcrumb-item"><a href="/seo-local-sud-oise-nord-95/">Sud Oise & Nord 95</a></li>
            <li class="breadcrumb-item active" aria-current="page">Senlis</li>
          </ol>
        </nav>

      </div>
    </div>

    <div class="video-overlay z-1" style="background-image: linear-gradient(to top, rgba(254,150,3,0.5), #39384D);"></div>
  </section>

  <section id="content">
    <div class="content-wrap pb-0">

      <div class="container">

        <div class="row align-items-center">
          <div class="col-lg-7">
            <div class="badge rounded-pill badge-default">Senlis</div>

            <h2 class="display-4 fw-bold">Un bassin “projets” : on optimise la demande de devis.</h2>

            <p>
              Sur Senlis, on vise souvent moins d’appels “urgents” et plus de <strong>demandes de devis</strong>.
              L’enjeu : <strong>rassurer</strong> (preuves, méthode, délais) et <strong>filtrer</strong> (zone / besoin / délai)
              pour ne garder que des demandes réellement traitables.
            </p>

            <p class="mb-4">
              Concrètement : on clarifie vos prestations (devis, projets, premium), votre rayon (communes fortes),
              puis on met en place des pages locales + un parcours devis simple.
              Ensuite, on suit l’essentiel : <strong>appels</strong>, <strong>formulaires</strong>, et la <strong>qualité</strong>.
            </p>

            <div class="d-flex flex-wrap gap-2">
              <a href="/contact/" class="button button-rounded button-large text-transform-none ls-0">Demander un audit</a>
              <a
                href="/seo-local-sud-oise-nord-95/"
                class="button button-rounded button-large button-light text-dark bg-white border text-transform-none ls-0"
              >
                Voir les autres zones
              </a>
              <a
                href="/faqs/"
                class="button button-rounded button-large button-light text-dark bg-white border text-transform-none ls-0"
              >
                FAQ
              </a>
            </div>

            <small class="text-muted d-block mt-3">
              Astuce : sur Senlis, les preuves (avis, photos, réalisations) + un process clair font souvent la différence sur la conversion.
            </small>

            <div class="mt-3">
              <small class="text-muted">
                Communes proches : {nearby.slice(0, 10).join(" • ")}…
              </small>
            </div>
          </div>

          <div class="col-lg-5 mt-4 mt-lg-0 text-center">
            <img
              src="/images/services/analysis.svg"
              alt="Rassurance et devis à Senlis"
              style="max-width: 420px;"
              loading="lazy"
            />
          </div>
        </div>

        <div class="clear line my-6"></div>

        <div class="heading-block border-bottom-0 text-center">
          <div class="badge rounded-pill badge-default">Ce que je mets en place</div>
          <h2 class="text-transform-none ls-0">Pour Senlis : rassurance, filtre, devis</h2>
          <p class="text-muted mb-0" style="max-width: 780px; margin: 0 auto;">
            Ici, l’objectif n’est pas le “volume” : c’est d’avoir des <strong>demandes premium</strong> (projets/devis)
            avec un parcours clair et des preuves.
          </p>
        </div>

        <div class="clear"></div>

        <div class="row mt-4 col-mb-50 mb-0">

          <!-- 1 -->
          <div class="col-sm-6 col-lg-4">
            <div class="feature-box">
              <div class="fbox-icon mb-4">
                <a href="/seo-local-sud-oise-nord-95/senlis/" aria-label="Pages locales Senlis">
                  <i class="fa-brands fa-google text-white bg-google"></i>
                </a>
              </div>
              <div class="fbox-content">
                <h3 class="text-transform-none">Pages locales + Google (SEO local)</h3>
                <p class="mb-0">
                  Une page dédiée à Senlis, avec <strong>prestations</strong>, <strong>zones</strong>, preuves et CTA
                  pour déclencher des <strong>demandes de devis</strong> (et des appels si besoin).
                </p>
                <small class="text-muted d-block mt-2">
                  Voir aussi : <a href="/seo-local-sud-oise-nord-95/">toutes les zones</a>
                </small>
              </div>
            </div>
          </div>

          <!-- 2 -->
          <div class="col-sm-6 col-lg-4">
            <div class="feature-box">
              <div class="fbox-icon mb-4">
                <a href="/faqs/" aria-label="Filtrage des demandes">
                  <i class="bi-funnel bg-dark border-0"></i>
                </a>
              </div>
              <div class="fbox-content">
                <h3 class="text-transform-none">Filtrage (anti hors-sujet)</h3>
                <p class="mb-0">
                  On filtre : <strong>hors zone</strong>, <strong>hors prestation</strong>, <strong>délai irréaliste</strong>, contact non joignable.
                  Objectif : garder des demandes exploitables (projets/devis).
                </p>
                <small class="text-muted d-block mt-2">
                  À lire : <a href="/faqs/">“demande qualifiée”, ça veut dire quoi ?</a>
                </small>
              </div>
            </div>
          </div>

          <!-- 3 -->
          <div class="col-sm-6 col-lg-4">
            <div class="feature-box">
              <div class="fbox-icon mb-4">
                <a href="/contact/" aria-label="Conversion et suivi">
                  <i class="bi-telephone bg-info border-0"></i>
                </a>
              </div>
              <div class="fbox-content">
                <h3 class="text-transform-none">Conversion + suivi simple</h3>
                <p class="mb-0">
                  Un parcours “devis” clair : CTA visibles, preuves, messages rassurants.
                  Puis un suivi simple : <strong>appels</strong>, <strong>formulaires</strong>, et qualité → ajustements.
                </p>
                <small class="text-muted d-block mt-2">
                  <a href="/contact/">Demander un audit</a> • réponse rapide (jours ouvrés)
                </small>
              </div>
            </div>
          </div>

        </div>

      </div>

      <div class="clear"></div>

      <!-- Zones autour / secteurs proches
      ============================================= -->
      <div class="section mb-0">
        <div class="container">
          <div class="heading-block border-bottom-0 text-center">
            <div class="badge rounded-pill badge-default">Zones autour</div>
            <h2 class="text-transform-none ls-0">Vous êtes proche de Senlis ?</h2>
            <p class="text-muted mb-0" style="max-width: 820px; margin: 0 auto;">
              Choisissez la page la plus proche de votre secteur. Chaque bassin a son approche (volume, concurrence, type de demandes).
            </p>
          </div>

          <div class="row col-mb-30 align-content-stretch">

            <!-- 1 : Senlis (page actuelle) -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/experience.svg" alt="Senlis" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">Senlis</h3>
                      <p class="text-smaller mb-0">
                        Zone “devis / projets” : moins de volume, plus de qualité (rassurance + process + filtrage).
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Senlis • Chamant</li>
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Aumont-en-Halatte (selon activité)</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : mieux qualifié</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 2 : Chantilly -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/content_marketing.svg" alt="Chantilly" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/chantilly/">Chantilly</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Bassin premium : pages orientées confiance (preuves, avis, photos, devis).
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Chantilly • Gouvieux</li>
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Lamorlaye • Coye-la-Forêt</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : rassurance</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 3 : Creil / Saint-Maximin -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/analysis.svg" alt="Creil / Saint-Maximin" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/creil-saint-maximin/">Creil / Saint-Maximin</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Zone concurrentielle : volume + filtrage pour garder des demandes utiles (appels + devis).
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Creil • Saint-Maximin</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : volume + tri</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 4 : Nord 95 -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/adword.svg" alt="Nord 95" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/nord-95/">Nord 95</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Si ton activité “monte” dans le 95 : ciblage serré + exclusions pour garder la qualité.
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Persan • Beaumont • L’Isle-Adam</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : ciblage</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 5 : Pont-Sainte-Maxence -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/seo.svg" alt="Pont-Sainte-Maxence" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/pont-sainte-maxence/">Pont-Sainte-Maxence</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Si tu veux capter “au sud” : zone intermédiaire avec demandes devis & appels.
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Pont-Sainte-Maxence • alentours</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : mix</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 6 : Hub (toutes les zones) -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/adword.svg" alt="Sud Oise & Nord 95" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/">Sud Oise & Nord 95 (hub)</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Accès rapide à toutes les pages zones + explications simples (SEO local, pub locale, conversion).
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Choisir la zone la plus proche</li>
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Comprendre l’approche par bassin</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> <a href="/contact/">Demander un audit</a></li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

          </div>

        </div>
      </div>

      <!-- Form Section (Senlis)
      ============================================= -->
      <div
        class="section mt-0"
        style="background: url('/images/sections/1.jpg') no-repeat center center; background-size: cover; padding: 100px 0;"
      >
        <div class="container">
          <div class="row justify-content-between align-items-center">

            <!-- Texte -->
            <div class="col-md-6">
              <div class="heading-block border-bottom-0 mb-4">
                <div class="badge rounded-pill badge-default">Audit rapide</div>
                <h2 class="text-transform-none ls-0">Senlis : rassurer, filtrer, convertir.</h2>
              </div>

              <p class="mb-3">
                Sur un bassin “devis / projets”, le plus important c’est une demande <strong>claire</strong> et <strong>qualifiée</strong> :
                <strong>zone OK</strong>, <strong>prestation OK</strong>, <strong>délai cohérent</strong>, contact joignable.
                On ajoute la <strong>rassurance</strong> (preuves + process).
              </p>

              <ul class="iconlist iconlist-color mb-4">
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Message</strong> : prestations + secteurs servis + délai</li>
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Preuves</strong> : avis / photos / réalisations</li>
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Filtre</strong> : hors zone / hors budget / hors délai</li>
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Suivi</strong> : appels + formulaires + qualité</li>
              </ul>

              <div class="d-flex flex-wrap gap-2">
                <a href="/seo-local-sud-oise-nord-95/" class="button button-rounded button-light text-dark bg-white border text-transform-none ls-0">
                  Voir toutes les zones
                </a>
                <a href="/faqs/" class="button button-rounded button-light text-dark bg-white border text-transform-none ls-0">
                  FAQ (réponses simples)
                </a>
              </div>

              <small class="text-muted d-block mt-3">
                Besoin premium “confiance” ?{" "}
                <a href="/seo-local-sud-oise-nord-95/chantilly/">Chantilly</a>
                {" "}•{" "}
                Besoin volume + tri ?{" "}
                <a href="/seo-local-sud-oise-nord-95/creil-saint-maximin/">Creil / Saint-Maximin</a>
              </small>
            </div>

            <!-- Form HubSpot -->
            <div class="col-lg-4 col-md-5 mt-5 mt-md-0">
              <div class="card shadow-sm">
                <div class="card-body">
                  <h3 class="mb-2">Demander un audit</h3>
                  <p class="text-muted mb-3">Réponse rapide (jours ouvrés).</p>

                  <HubspotForm
                    context={{
                      page_type: "zone",
                      zone: "Senlis",
                      area: "Sud Oise / Nord 95",
                      page_url: Astro.url.pathname,
                    }}
                  />

                  <small class="text-muted d-block mt-3">
                    Pas de spam. Un échange pour cadrer la zone + le type de demandes à viser.
                  </small>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>

      <!-- FAQ express -->
      <div class="section bg-transparent mt-0" style="background: url('/images/sections/3.jpg') no-repeat top center; background-size: cover; padding: 0 0 70px;">
        <div class="container">
          <div class="heading-block border-bottom-0 text-center">
            <div class="badge rounded-pill badge-default">FAQ express</div>
            <h2 class="text-transform-none ls-0">Questions fréquentes (Senlis)</h2>
            <p class="text-muted mb-0">
              Bassin “devis / projets” : rassurance + filtrage pour garder des demandes premium. Réponses courtes.
            </p>
          </div>

          <div class="row justify-content-center">
            <div class="col-lg-10">
              {quickFaqs.map((item) => (
                <div class="toggle faq pb-3 mb-4">
                  <div class="toggle-header">
                    <div class="toggle-icon color">
                      <i class="toggle-closed bi-question-circle"></i>
                      <i class="toggle-open bi-question-circle"></i>
                    </div>
                    <div class="toggle-title fw-semibold ps-1">{item.q}</div>
                    <div class="toggle-icon color">
                      <i class="toggle-closed fa-solid fa-chevron-down text-black-50"></i>
                      <i class="toggle-open fa-solid fa-chevron-up color"></i>
                    </div>
                  </div>

                  <div class="toggle-content text-black-50 ps-4">
                    {item.a}

                    <div class="mt-2">
                      <small class="text-muted">
                        Besoin d’une reco rapide ?{" "}
                        <a href="/contact/">Demander un audit</a>
                        {" "}•{" "}
                        <a href="/seo-local-sud-oise-nord-95/">Voir toutes les zones</a>
                        {" "}•{" "}
                        Zones proches :{" "}
                        <a href="/seo-local-sud-oise-nord-95/chantilly/">Chantilly</a>
                        {" "}•{" "}
                        <a href="/seo-local-sud-oise-nord-95/creil-saint-maximin/">Creil / Saint-Maximin</a>
                      </small>
                    </div>
                  </div>
                </div>
              ))}

              <div class="text-center d-flex flex-wrap justify-content-center gap-2">
                <a href="/faqs/" class="button button-rounded text-transform-none ls-0">Voir toutes les FAQ</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Promo/Contact (Senlis)
      ============================================= -->
      <div
        class="section mt-5"
        style="padding: 100px 0; overflow: visible; background: url('/images/sections/3.jpg') no-repeat top center; background-size: cover;"
      >
        <div class="container">
          <div class="heading-block border-bottom-0 text-center">
            <div class="h5 text-uppercase ls-1 mb-2">Senlis • Chamant • Aumont-en-Halatte</div>

            <h2 class="text-transform-none ls-0 mb-3">
              Vous voulez plus de <span>demandes de devis</span>…
              <br class="d-none d-md-block" />
              avec des clients réellement “sérieux” ?
            </h2>

            <p class="text-muted mb-0" style="max-width: 820px; margin: 0 auto;">
              On fait un point rapide : votre zone réelle, vos prestations, et le niveau de demande à viser.
              Ensuite je te dis si le plus pertinent est <strong>SEO local</strong>, <strong>pub locale</strong>, ou un <strong>mix</strong>
