---
import Layout from "../../layouts/Layout.astro";
import HubspotForm from "../../components/HubspotForm.astro";
import { SITE } from "../../config/site";

const pageUrl = Astro.url.pathname;

const zoneLabel = "Sud de l’Oise & Nord Val-d’Oise (95)";
const pageTitle = `Consultant webmarketing ${zoneLabel} | SEO local + Pub + Site (conversion)`;
const description =
  `SEO local, pub locale si besoin et site clair qui convertit en appels/devis. Intervention ${zoneLabel}. Audit rapide.`;

const pages = [
  { slug: "chambly", label: "Chambly", note: "Local • volume maîtrisé" },
  { slug: "le-mesnil-en-thelle", label: "Le Mesnil-en-Thelle", note: "Local • villages / proximité" },
  { slug: "creil-saint-maximin", label: "Creil / Saint-Maximin", note: "Bassin creillois • concurrence" },
  { slug: "nogent-montataire", label: "Nogent / Montataire", note: "Bassin creillois • différenciation" },
  { slug: "meru", label: "Méru", note: "Ouest Oise • zone étendue" },
  { slug: "senlis", label: "Senlis", note: "Projets • demandes plus qualifiées" },
  { slug: "chantilly", label: "Chantilly", note: "Premium • rassurance & devis" },
  { slug: "nord-95", label: "Nord 95", note: "Persan / Beaumont / L’Isle-Adam" },
];

const services = [
  { icon: "bi-search", title: "SEO local", desc: "Pages locales propres + fiche Google bien reliée au site." },
  { icon: "bi-megaphone", title: "Pub locale (option)", desc: "Pour accélérer ou lisser le planning. Ciblage précis." },
  { icon: "bi-telephone", title: "Site qui convertit", desc: "Contact simple, preuves, CTA visibles. Moins de friction." },
  { icon: "bi-bar-chart", title: "Suivi & ajustements", desc: "On suit appels + formulaires + qualité. On améliore." },
];

const steps = [
  { icon: "bi-compass", title: "1) Cadrage", desc: "Zone (rayon), services, priorités (dépannage / devis), capacité." },
  { icon: "bi-tools", title: "2) Mise en place", desc: "Pages locales + parcours contact + tracking simple." },
  { icon: "bi-graph-up", title: "3) Lancement", desc: "SEO local en continu + pub locale si besoin." },
  { icon: "bi-sliders", title: "4) Amélioration", desc: "On garde ce qui marche, on coupe le bruit, on filtre mieux." },
];

const faq = [
  { cat: "faq-zone", icon: "bi-geo-alt", q: "Tu interviens sur quelle zone ?", a: `Principalement : <strong>${SITE.area ?? zoneLabel}</strong>. On démarre sur une zone réaliste, puis on étend si tout est OK.` },
  { cat: "faq-qualif", icon: "bi-question-circle", q: "C’est quoi une demande “qualifiée” ?", a: "Une demande est qualifiée si elle respecte les critères fixés ensemble : <strong>zone</strong>, <strong>prestation</strong>, <strong>délai</strong> cohérent et <strong>contact joignable</strong>." },
  { cat: "faq-zone", icon: "bi-speedometer2", q: "Combien de demandes je peux recevoir ?", a: "Ça dépend du secteur et de la saison. Le plus important : on règle le volume selon ta capacité (on baisse si tu es plein)." },
  { cat: "faq-prix", icon: "bi-credit-card", q: "Ça coûte combien ?", a: "Ça dépend de la zone, du niveau de concurrence et de l’objectif (plus de volume vs plus qualifié). Je te donne un prix clair après un point rapide." },
  { cat: "faq-demarrage", icon: "bi-play-circle", q: "En combien de temps ça démarre ?", a: "Après cadrage, on peut démarrer vite. Le délai dépend surtout des réglages et du contenu à créer/améliorer." },
  { cat: "faq-divers", icon: "bi-telephone", q: "Comment tu mesures si ça marche ?", a: "On suit l’essentiel : appels, formulaires, zones, et qualité. Puis on ajuste." },
];

const clusters = [
  {
    title: "Thelle & autour de Chambly",
    desc: "Idéal si tu travailles sur un rayon “villages / proximité”.",
    links: [
      { href: "/seo-local-sud-oise-nord-95/chambly/", label: "Chambly : demandes locales" },
      { href: "/seo-local-sud-oise-nord-95/le-mesnil-en-thelle/", label: "Le Mesnil-en-Thelle : proximité" },
      { href: "/seo-local-sud-oise-nord-95/meru/", label: "Méru : zone étendue" },
    ],
  },
  {
    title: "Bassin Creil / Nogent / Montataire",
    desc: "Zone concurrentielle : clarté + filtrage = demandes utiles.",
    links: [
      { href: "/seo-local-sud-oise-nord-95/creil-saint-maximin/", label: "Creil / Saint-Maximin : qualifié" },
      { href: "/seo-local-sud-oise-nord-95/nogent-montataire/", label: "Nogent / Montataire : appels & devis" },
    ],
  },
  {
    title: "Premium (projets / devis)",
    desc: "Moins de volume, plus de qualité (preuves + process + devis).",
    links: [
      { href: "/seo-local-sud-oise-nord-95/senlis/", label: "Senlis : mieux qualifié" },
      { href: "/seo-local-sud-oise-nord-95/chantilly/", label: "Chantilly : premium / devis" },
    ],
  },
  {
    title: "Nord Val-d’Oise (95)",
    desc: "Zone frontière : ciblage précis pour éviter le hors zone.",
    links: [
      { href: "/seo-local-sud-oise-nord-95/nord-95/", label: "Nord 95 : Persan / Beaumont / L’Isle-Adam" },
      { href: "/seo-local-sud-oise-nord-95/chambly/", label: "Chambly (connexion Oise/95)" },
    ],
  },
];
---

<Layout title={pageTitle} description={description}>
  <!-- Page Title -->
  <section class="page-title page-title-parallax parallax scroll-detect page-title-center dark include-header include-topbar">
    <img src="/images/services/analysis-title.jpg" class="parallax-bg" alt="" />
    <div id="particles-line"></div>

    <div class="container">
      <div class="page-title-row">
        <div class="page-title-content">
          <div class="badge rounded-pill border border-light text-light">Consultant webmarketing</div>
          <h1>{zoneLabel} : plus de demandes locales</h1>
        </div>

        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Accueil</a></li>
            <li class="breadcrumb-item active" aria-current="page">Sud Oise / Nord 95</li>
          </ol>
        </nav>
      </div>
    </div>

    <div class="video-overlay z-1" style="background-image: linear-gradient(to top, rgba(254,150,3,0.5), #39384D);"></div>
  </section>

  <section id="content">
    <div class="content-wrap pb-0">
      <div class="container">

        <!-- Intro -->
        <div class="row align-items-center">
          <div class="col-lg-7">
            <div class="badge rounded-pill badge-default">Pack complet</div>
            <h2 class="display-4 fw-bold">SEO local + pub (si besoin) + site clair qui convertit.</h2>

            <p>
              Je suis <strong>consultant webmarketing</strong> : je m’occupe de la visibilité (Google),
              et je fais en sorte que ton site transforme en <strong>appels</strong> et <strong>demandes de devis</strong>.
            </p>

            <ul class="iconlist iconlist-color mb-4">
              <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Zone</strong> : ciblée (rayon / villes)</li>
              <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Objectif</strong> : demandes utiles (pas du volume inutile)</li>
              <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Suivi</strong> : appels + formulaires + qualité</li>
              <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Ajustements</strong> : on garde ce qui marche</li>
            </ul>

            <a href="/contact/" class="button button-rounded button-large text-transform-none ls-0">Demander un audit</a>
            {SITE?.phoneE164 && (
              <a href={`tel:${SITE.phoneE164}`} class="button button-rounded button-large button-light text-dark bg-white border text-transform-none ls-0">
                Appeler
              </a>
            )}
          </div>

          <div class="col-lg-5 mt-4 mt-lg-0">
            <img src="/images/sections/2.png" alt="" />
          </div>
        </div>

        <div class="clear line my-6"></div>

        <!-- Méthode -->
        <div class="heading-block border-bottom-0 text-center">
          <div class="badge rounded-pill badge-default">Méthode</div>
          <h3 class="text-transform-none ls-0">Simple, locale, mesurable</h3>
        </div>

        <div class="row mt-4 col-mb-30">
          {steps.map((s) => (
            <div class="col-md-6 col-lg-3">
              <div class="feature-box">
                <div class="fbox-icon mb-3">
                  <i class={`${s.icon} text-white bg-color`}></i>
                </div>
                <div class="fbox-content">
                  <h3 class="text-transform-none">{s.title}</h3>
                  <p class="mb-0 text-muted">{s.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="clear line my-6"></div>

        <!-- Offre -->
        <div class="heading-block border-bottom-0 text-center">
          <div class="badge rounded-pill badge-default">Offre</div>
          <h3 class="text-transform-none ls-0">Le pack complet</h3>
        </div>

        <div class="row mt-4 col-mb-50 mb-0">
          {services.map((s) => (
            <div class="col-sm-6 col-lg-3">
              <div class="feature-box">
                <div class="fbox-icon mb-4">
                  <i class={`${s.icon} text-white bg-color`}></i>
                </div>
                <div class="fbox-content">
                  <h3 class="text-transform-none">{s.title}</h3>
                  <p class="mb-0 text-muted">{s.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="clear line my-6"></div>

        <!-- Pages -->
        <div class="heading-block border-bottom-0 text-center">
          <div class="badge rounded-pill badge-default">Pages locales</div>
          <h3 class="text-transform-none ls-0">8 pôles (pas 8 pages clones)</h3>
          <p class="text-muted mb-0">
            Chaque page correspond à un bassin (niveau de concurrence, type de demandes, logique de rayon).
          </p>
        </div>

        <div class="row col-mb-30 align-content-stretch mt-4">
          {pages.map((p) => (
            <div class="col-lg-3 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-4">
                  <h3 class="text-transform-none ls-0 mb-1">
                    <a class="nav-link" href={`/seo-local-sud-oise-nord-95/${p.slug}/`}>{p.label}</a>
                  </h3>
                  <p class="text-muted mb-0">{p.note}</p>
                  <div class="mt-3">
                    <a class="button button-small button-rounded text-transform-none ls-0" href={`/seo-local-sud-oise-nord-95/${p.slug}/`}>Voir la page</a>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="clear line my-6"></div>

        <div class="heading-block border-bottom-0 text-center">
          <div class="badge rounded-pill badge-default">Maillage</div>
          <h3 class="text-transform-none ls-0">Choisir la page la plus pertinente</h3>
          <p class="text-muted mb-0">Chaque page correspond à un bassin (zone, concurrence, type de demandes).</p>
        </div>

        <div class="row col-mb-30 align-content-stretch mt-4">
          {clusters.map((c) => (
            <div class="col-lg-3 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-4">
                  <h4 class="text-transform-none ls-0 mb-2">{c.title}</h4>
                  <p class="text-muted mb-3">{c.desc}</p>
                  <ul class="iconlist ms-3 mb-0">
                    {c.links.map((l) => (
                      <li class="mb-2 text-muted">
                        <i class="fa-solid fa-check text-smaller color"></i>{" "}
                        <a class="nav-link d-inline" href={l.href}>{l.label}</a>
                      </li>
                    ))}
                    <li class="text-muted">
                      <i class="fa-solid fa-check text-smaller color"></i>{" "}
                      <a class="nav-link d-inline" href="/contact/">Demander un audit</a>
                    </li>
                  </ul>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="clear line my-6"></div>

        <!-- FAQ -->
        <div class="heading-block border-bottom-0 text-center">
          <div class="badge rounded-pill badge-default">FAQ</div>
          <h3 class="text-transform-none ls-0">Réponses simples</h3>
        </div>

        <div class="row justify-content-center mt-4">
          <div class="col-lg-10">
            <div id="faqs" class="faqs">
              {faq.map((f) => (
                <div class={`toggle faq pb-3 mb-4 ${f.cat}`}>
                  <div class="toggle-header">
                    <div class="toggle-icon color">
                      <i class={`toggle-closed ${f.icon}`}></i>
                      <i class={`toggle-open ${f.icon}`}></i>
                    </div>
                    <div class="toggle-title fw-semibold ps-1">{f.q}</div>
                    <div class="toggle-icon color">
                      <i class="toggle-closed fa-solid fa-chevron-down text-black-50"></i>
                      <i class="toggle-open fa-solid fa-chevron-up color"></i>
                    </div>
                  </div>
                  <div class="toggle-content text-black-50 ps-4" set:html={f.a} />
                </div>
              ))}
            </div>
          </div>
        </div>

      </div>

      <!-- Form Section -->
      <div
        class="section mt-0"
        style="background: url('/images/sections/1.jpg') no-repeat center center; background-size: cover; padding: 100px 0;"
      >
        <div class="container">
          <div class="row justify-content-between align-items-center">

            <div class="col-lg-6 col-md-6">
              <div class="heading-block border-bottom-0 mb-4">
                <div class="badge rounded-pill badge-default">Audit</div>
                <h3 class="text-transform-none ls-0">
                  On regarde ensemble comment générer plus de demandes (local).
                </h3>
              </div>

              <p class="mb-3">
                Zone, services, capacité, priorité (devis / urgence). Je te propose le plan le plus simple.
              </p>

              <ul class="iconlist iconlist-color mb-0">
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Zone</strong> : {SITE.area ?? zoneLabel}</li>
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Objectif</strong> : appels + devis</li>
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Approche</strong> : claire, mesurable</li>
              </ul>
            </div>

            <div class="col-lg-4 col-md-5 mt-5 mt-md-0">
              <div class="card shadow-sm">
                <div class="card-body">
                  <h4 class="mb-3">Demander un audit</h4>

                  <HubspotForm
                    context={{
                      page_type: "local-hub",
                      zone: zoneLabel,
                      offer: "Pack complet SEO + Pub + Conversion",
                      page_url: pageUrl,
                    }}
                  />

                  <small class="text-muted d-block mt-3">Réponse rapide (jours ouvrés).</small>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>
