---
import Layout from "../../layouts/Layout.astro";
import HubspotForm from "../../components/HubspotForm.astro";
import { SITE } from "../../config/site";

const pageUrl = Astro.url.pathname;

const zoneLabel = "Sud de l’Oise & Nord Val-d’Oise (95)";
const pageTitle = `Consultant webmarketing Sud Oise & Nord 95 | SEO local + pub`;
const description =
  `SEO local + pub si besoin + site clair qui génère appels et demandes de devis. Intervention Sud Oise & Nord 95. Audit rapide.`;

const pages = [
  { slug: "chambly", label: "Chambly", note: "Local • volume maîtrisé" },
  { slug: "le-mesnil-en-thelle", label: "Le Mesnil-en-Thelle", note: "Local • villages / proximité" },
  { slug: "creil-saint-maximin", label: "Creil / Saint-Maximin", note: "Bassin creillois • concurrence" },
  { slug: "nogent-montataire", label: "Nogent / Montataire", note: "Bassin creillois • différenciation" },
  { slug: "meru", label: "Méru", note: "Ouest Oise • zone étendue" },
  { slug: "senlis", label: "Senlis", note: "Projets • demandes plus qualifiées" },
  { slug: "chantilly", label: "Chantilly", note: "Premium • rassurance & devis" },
  { slug: "nord-95", label: "Nord 95", note: "Persan / Beaumont / L’Isle-Adam" },
];

const services = [
  { icon: "bi-search", title: "SEO local", desc: "Pages locales propres + fiche Google bien reliée au site." },
  { icon: "bi-megaphone", title: "Pub locale (option)", desc: "Pour accélérer ou lisser le planning. Ciblage précis." },
  { icon: "bi-telephone", title: "Site qui convertit", desc: "Contact simple, preuves, CTA visibles. Moins de friction." },
  { icon: "bi-bar-chart", title: "Suivi & ajustements", desc: "On suit appels + formulaires + qualité. On améliore." },
];

const steps = [
  { icon: "bi-compass", title: "1) Cadrage", desc: "Zone (rayon), services, priorités (dépannage / devis), capacité." },
  { icon: "bi-tools", title: "2) Mise en place", desc: "Pages locales + parcours contact + tracking simple." },
  { icon: "bi-graph-up", title: "3) Lancement", desc: "SEO local en continu + pub locale si besoin." },
  { icon: "bi-sliders", title: "4) Amélioration", desc: "On garde ce qui marche, on coupe le bruit, on filtre mieux." },
];

const faq = [
  { cat: "faq-zone", icon: "bi-geo-alt", q: "Tu interviens sur quelle zone ?", a: `Principalement : <strong>${SITE.area ?? zoneLabel}</strong>. On démarre sur une zone réaliste, puis on étend si tout est OK.` },
  { cat: "faq-qualif", icon: "bi-question-circle", q: "C’est quoi une demande “qualifiée” ?", a: "Une demande est qualifiée si elle respecte les critères fixés ensemble : <strong>zone</strong>, <strong>prestation</strong>, <strong>délai</strong> cohérent et <strong>contact joignable</strong>." },
  { cat: "faq-zone", icon: "bi-speedometer2", q: "Combien de demandes je peux recevoir ?", a: "Ça dépend du secteur et de la saison. Le plus important : on règle le volume selon ta capacité (on baisse si tu es plein)." },
  { cat: "faq-prix", icon: "bi-credit-card", q: "Ça coûte combien ?", a: "Ça dépend de la zone, du niveau de concurrence et de l’objectif (plus de volume vs plus qualifié). Je te donne un prix clair après un point rapide." },
  { cat: "faq-demarrage", icon: "bi-play-circle", q: "En combien de temps ça démarre ?", a: "Après cadrage, on peut démarrer vite. Le délai dépend surtout des réglages et du contenu à créer/améliorer." },
  { cat: "faq-divers", icon: "bi-telephone", q: "Comment tu mesures si ça marche ?", a: "On suit l’essentiel : appels, formulaires, zones, et qualité. Puis on ajuste." },
];

const clusters = [
  {
    title: "Thelle & autour de Chambly",
    desc: "Idéal si tu travailles sur un rayon “villages / proximité”.",
    links: [
      { href: "/seo-local-sud-oise-nord-95/chambly/", label: "Chambly : demandes locales" },
      { href: "/seo-local-sud-oise-nord-95/le-mesnil-en-thelle/", label: "Le Mesnil-en-Thelle : proximité" },
      { href: "/seo-local-sud-oise-nord-95/meru/", label: "Méru : zone étendue" },
    ],
  },
  {
    title: "Bassin Creil / Nogent / Montataire",
    desc: "Zone concurrentielle : clarté + filtrage = demandes utiles.",
    links: [
      { href: "/seo-local-sud-oise-nord-95/creil-saint-maximin/", label: "Creil / Saint-Maximin : qualifié" },
      { href: "/seo-local-sud-oise-nord-95/nogent-montataire/", label: "Nogent / Montataire : appels & devis" },
    ],
  },
  {
    title: "Premium (projets / devis)",
    desc: "Moins de volume, plus de qualité (preuves + process + devis).",
    links: [
      { href: "/seo-local-sud-oise-nord-95/senlis/", label: "Senlis : mieux qualifié" },
      { href: "/seo-local-sud-oise-nord-95/chantilly/", label: "Chantilly : premium / devis" },
    ],
  },
  {
    title: "Nord Val-d’Oise (95)",
    desc: "Zone frontière : ciblage précis pour éviter le hors zone.",
    links: [
      { href: "/seo-local-sud-oise-nord-95/nord-95/", label: "Nord 95 : Persan / Beaumont / L’Isle-Adam" },
      { href: "/seo-local-sud-oise-nord-95/chambly/", label: "Chambly (connexion Oise/95)" },
    ],
  },
];

const quickFaqs = [
  {
    q: "C’est quoi une “demande qualifiée” exactement ?",
    a: "Une demande est qualifiée si elle correspond à votre zone + à vos prestations, avec un délai réaliste et un contact joignable. Si ça ne colle pas, on ne la considère pas comme utile.",
    tag: "qualif",
  },
  {
    q: "Vous couvrez quelles zones (Sud Oise / Nord 95) ?",
    a: "On travaille par bassins (ex : Creil / Nogent, Senlis / Chantilly, Méru, Nord 95…). Le plus important : choisir une zone que vous pouvez réellement traiter.",
    tag: "zone",
  },
  {
    q: "Combien de demandes je peux recevoir ?",
    a: "Ça dépend du métier, de la concurrence et de la zone. On règle surtout le volume selon votre planning : si vous êtes plein, on baisse. Si vous avez de la place, on relance.",
    tag: "volume",
  },
  {
    q: "SEO local ou pub : qu’est-ce qui marche le mieux ?",
    a: "SEO = durable (progressif). Pub = plus rapide (réglable). Le plus efficace est souvent un mix, surtout au démarrage.",
    tag: "canaux",
  },
  {
    q: "Est-ce que vous travaillez avec artisans, commerces et indépendants ?",
    a: "Oui. L’approche change selon l’activité : urgence (appels), devis (formulaire), premium (preuve + rassurance).",
    tag: "cibles",
  },
  {
    q: "Combien de temps avant de voir des résultats ?",
    a: "La pub peut démarrer vite. Le SEO prend plus de temps mais dure. Dans tous les cas : on met d’abord en place un parcours clair (preuve, zone, prestations, CTA).",
    tag: "delai",
  },
];
---

<Layout title={pageTitle} description={description}>
  <!-- Hero
  ============================================= -->
  <section id="slider" class="slider-element slider-parallax min-vh-60 min-vh-md-100 include-header">
    <div
      class="slider-inner"
      style="background: var(--cnvs-contrast-0) url('/images/hero/hero-1.jpg') center center no-repeat; background-size: cover;"
    >
      <div class="vertical-middle slider-element-fade">
        <div class="container py-5">
          <div class="row pt-6">
            <div class="col-lg-6 col-md-9">
              <div class="slider-title">
                <div class="badge rounded-pill badge-default">Sud Oise & Nord 95</div>

                <h1 class="mb-3">Des demandes locales, pas du blabla.</h1>

                <h2
                  class="h3 text-rotater mb-3"
                  data-separator=","
                  data-rotate="fadeIn"
                  data-speed="3200"
                >
                  Je vous aide à recevoir
                  <span class="t-rotate">des appels,des formulaires,des devis</span>
                  dans votre secteur.
                </h2>

                <p class="mb-4">
                  J’accompagne les artisans, commerces et indépendants du <strong>Sud de l’Oise</strong> et du
                  <strong>Nord Val-d’Oise</strong> pour générer des demandes entrantes.
                </p>

                <div class="d-flex flex-wrap gap-2">
                  <a href="/contact/" class="button button-rounded button-large text-transform-none ls-0">
                    Demander un audit
                  </a>
                  <a
                    href="#zones" data-scrollto="#zones"
                    class="button button-rounded button-large button-light text-dark bg-white border text-transform-none ls-0"
                  >
                    Voir les zones couvertes
                  </a>
                </div>

                <div class="mt-4">
                  <small class="text-muted d-block">
                    Exemple de bassins : Chambly / Thelle, Creil / Nogent / Montataire, Senlis / Chantilly, Méru, Nord 95…
                  </small>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="video-wrap h-100 d-block d-lg-none">
        <div class="video-overlay" style="background: rgba(255,255,255,0.85);"></div>
      </div>
    </div>
  </section><!-- #slider end -->

  <section id="content">
    <div class="content-wrap pt-0">

      <!-- Ce que je fais
      ============================================= -->
      <div class="section bg-transparent mt-4 mb-0 pb-0">
        <div class="container">

          <div class="heading-block border-bottom-0 text-center mx-auto mb-0" style="max-width: 650px">
            <div class="badge rounded-pill badge-default">Ce que je fais</div>
            <h2 class="text-transform-none ls-0 mb-3">Générer des demandes locales</h2>
            <p>
              Mon job : vous apporter des <strong>appels</strong> et des <strong>demandes de devis</strong> dans votre zone,
              puis optimiser le parcours pour que ça se transforme en clients.
            </p>
          </div>

          <div class="row justify-content-between align-items-center">

            <!-- Col gauche -->
            <div class="col-lg-4 col-sm-6">

              <div class="feature-box flex-md-row-reverse text-md-end border-0">
                <div class="fbox-icon">
                  <a href="/seo-local-sud-oise-nord-95/" aria-label="SEO local"><img src="/images/icons/seo.svg" alt="SEO local" class="bg-transparent rounded-0"></a>
                </div>
                <div class="fbox-content">
                  <h3 class="text-transform-none ls-0">SEO local (Google)</h3>
                  <p class="mb-0">
                    Vous remontez sur les recherches locales.
                    Pages par zone + contenus, pensés pour ranker et convertir.
                  </p>
                </div>
              </div>

              <div class="feature-box flex-md-row-reverse text-md-end border-0 mt-5">
                <div class="fbox-icon">
                  <a href="/contact/" aria-label="Publicité locale"><img src="/images/icons/adword.svg" alt="Publicité locale" class="bg-transparent rounded-0"></a>
                </div>
                <div class="fbox-content">
                  <h3 class="text-transform-none ls-0">Pub locale (Google / Meta)</h3>
                  <p class="mb-0">
                    Quand il faut du résultat vite : campagnes ciblées par zone, avec filtrage pour limiter le hors-sujet.
                  </p>
                </div>
              </div>

              <div class="feature-box flex-md-row-reverse text-md-end border-0 mt-5">
                <div class="fbox-icon">
                  <a href="/faqs/" aria-label="Suivi et pilotage"><img src="/images/icons/analysis.svg" alt="Suivi et pilotage" class="bg-transparent rounded-0"></a>
                </div>
                <div class="fbox-content">
                  <h3 class="text-transform-none ls-0">Suivi & pilotage (simple)</h3>
                  <p class="mb-0">
                    On suit ce qui compte : appels, formulaires, devis signés.
                    Ajustements selon votre planning.
                  </p>
                </div>
              </div>

            </div>

            <!-- Image centre -->
            <div class="col-lg-3 col-7 offset-3 offset-sm-0 d-sm-none d-lg-block text-center my-5">
              <img
                src="/images/sections/2.png"
                alt="Performance locale"
                class="rounded parallax"
                data-bottom-top="transform: translateY(-30px)"
                data-top-bottom="transform: translateY(30px)"
              >
            </div>

            <!-- Col droite -->
            <div class="col-lg-4 col-sm-6">

              <div class="feature-box border-0">
                <div class="fbox-icon">
                  <a href="/contact/" aria-label="Conversion"><img src="/images/icons/experience.svg" alt="Conversion" class="bg-transparent rounded-0"></a>
                </div>
                <div class="fbox-content">
                  <h3 class="text-transform-none ls-0">Conversion (site & pages)</h3>
                  <p class="mb-0">
                    Une page claire = plus d’appels. On simplifie : preuves, zones, prestations,
                    formulaire court, et message qui rassure.
                  </p>
                </div>
              </div>

              <div class="feature-box border-0 mt-5">
                <div class="fbox-icon">
                  <a href="#zones" data-scrollto="#zones" aria-label="Pages par zones"><img src="/images/icons/content_marketing.svg" alt="Pages par zones" class="bg-transparent rounded-0"></a>
                </div>
                <div class="fbox-content">
                  <h3 class="text-transform-none ls-0">Pages par zone</h3>
                  <p class="mb-0">
                    Chaque bassin a sa logique (concurrence, rayon, type de demandes).
                    Ça évite les pages “dupliquées” et c’est meilleur pour Google.
                  </p>
                </div>
              </div>

              <div class="feature-box border-0 mt-5">
                <div class="fbox-icon">
                  <a href="/contact/" aria-label="Pack complet"><img src="/images/icons/social.svg" alt="Pack complet" class="bg-transparent rounded-0"></a>
                </div>
                <div class="fbox-content">
                  <h3 class="text-transform-none ls-0">Pack complet</h3>
                  <p class="mb-0">
                    On combine le long terme (SEO) + le court terme (pub) + l’efficacité (conversion).
                    Objectif : des demandes <strong>qualifiées</strong>.
                  </p>
                </div>
              </div>

            </div>

          </div>

        </div>
      </div>

      <!-- Offres
      ============================================= -->
      <div class="section m-0" style="background: url('/images/sections/4.png') no-repeat center top; background-size: cover; padding: 140px 0 0;">
        <div class="container">
          <div class="row justify-content-between">

            <!-- Intro -->
            <div class="col-lg-4 mt-4">
              <div class="heading-block border-bottom-0 mb-4">
                <div class="badge rounded-pill badge-default">Offres</div>
                <h2 class="text-transform-none ls-0">
                  Un cadre clair.<br />Des actions concrètes.
                </h2>
              </div>

              <p class="mb-4">
                Je suis consultant webmarketing local (Sud Oise / Nord 95).
                Mon objectif : <strong>générer des demandes entrantes</strong> (appels + formulaires) et
                <strong>augmenter le taux de transformation</strong> (devis / ventes).
              </p>

              <ul class="iconlist iconlist-color mb-4">
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Zone</strong> : villes / rayon cohérents</li>
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Offre</strong> : prestations + filtres (budget, délai)</li>
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Suivi</strong> : appels, formulaires, demandes utiles</li>
              </ul>

              <small class="text-muted d-block mt-3">
                Les tarifs dépendent du métier, de la zone et du volume souhaité. Je te dis ce qui est réaliste dès le premier échange.
              </small>
            </div>

            <!-- Cards -->
            <div class="col-lg-8">
              <div id="section-pricing" class="page-section p-0 m-0">

                <div class="pricing row align-items-stretch g-0 col-mb-50 mb-4">

                  <!-- Offre 1 -->
                  <div class="col-md-6">
                    <div class="pricing-box h-100">
                      <div class="pricing-title">
                        <img class="mb-2 bg-transparent rounded-0" src="/images/icons/man.svg" alt="Pack Démarrage" width="50">
                        <h3 class="text-transform-none ls-0">Pack Démarrage</h3>
                        <span>Pour lancer proprement</span>
                      </div>

                      <div class="pricing-price">
                        <span class="price-tenure">Audit + mise en place</span>
                      </div>

                      <div class="pricing-features border-0 bg-transparent">
                        <ul>
                          <li><i class="fa-solid fa-check-circle color me-2"></i><strong>Audit express</strong> : offre, zone, concurrence</li>
                          <li><i class="fa-solid fa-check-circle color me-2"></i><strong>Pages locales</strong> : hub + pages zones (propres)</li>
                          <li><i class="fa-solid fa-check-circle color me-2"></i><strong>Parcours</strong> : preuves, CTA, formulaire court</li>
                          <li><i class="fa-solid fa-check-circle color me-2"></i><strong>Mesure</strong> : appels + formulaires</li>
                          <li><i class="fa-solid fa-check-circle color me-2"></i><strong>Plan d’action</strong> : priorités + quick wins</li>
                        </ul>
                      </div>

                      <div class="pricing-action">
                        <a href="#audit" data-scrollto="#audit" class="button button-large button-rounded w-100 text-transform-none m-0 ls-0">
                          Demander un audit
                        </a>
                      </div>

                      <small class="text-muted d-block mt-3 px-4 pb-4">
                        Idéal si tu veux des bases solides et une trajectoire claire.
                      </small>
                    </div>
                  </div>

                  <!-- Offre 2 -->
                  <div class="col-md-6">
                    <div class="pricing-box h-100">
                      <div class="pricing-title">
                        <img class="mb-2 bg-transparent rounded-0" src="/images/icons/group.svg" alt="Pack Complet" width="60">
                        <h3 class="text-transform-none ls-0">Pack Complet</h3>
                        <span>SEO + Pub + Conversion</span>
                      </div>

                      <div class="pricing-price">
                        <span class="price-tenure">Mise en place + pilotage</span>
                      </div>

                      <div class="pricing-features border-0 bg-transparent">
                        <ul>
                          <li><i class="fa-solid fa-check-circle color me-2"></i><strong>SEO local</strong> : visibilité durable</li>
                          <li><i class="fa-solid fa-check-circle color me-2"></i><strong>Publicité</strong> : résultats plus rapides</li>
                          <li><i class="fa-solid fa-check-circle color me-2"></i><strong>Conversion</strong> : plus d’appels / formulaires</li>
                          <li><i class="fa-solid fa-check-circle color me-2"></i><strong>Filtrage</strong> : éviter le hors zone / hors budget</li>
                          <li><i class="fa-solid fa-check-circle color me-2"></i><strong>Optimisation continue</strong> : on ajuste selon ton planning</li>
                        </ul>
                      </div>

                      <div class="pricing-action">
                        <a href="/contact/" class="button button-rounded button-large button-light text-dark bg-white border w-100 text-transform-none m-0 ls-0">
                          Voir si c’est adapté
                        </a>
                      </div>

                      <small class="text-muted d-block mt-3 px-4 pb-4">
                        Recommandé si tu veux du court terme + du long terme, sans perdre de temps.
                      </small>
                    </div>
                  </div>

                </div>

                <!-- Micro-copy rassurante -->
                <div class="text-center pb-5">
                  <small class="text-muted">
                    Pas de promesse magique : on fait simple, mesurable, et adapté à ta zone.
                    <a href="/faqs/" class="ms-1">Questions fréquentes</a>
                  </small>
                </div>

              </div>
            </div>

          </div>
        </div>
      </div>

      <!-- Form Section
      ============================================= -->
      <div
        id="audit"
        class="section m-0"
        style="background: url('/images/sections/1.jpg') no-repeat center center; background-size: cover; padding: 100px 0;"
      >
        <div class="container">
          <div class="row justify-content-between align-items-center">

            <!-- Texte -->
            <div class="col-md-5">
              <div class="heading-block border-bottom-0 mb-4">
                <div class="badge rounded-pill badge-default">Recevoir des demandes</div>
                <h2 class="text-transform-none ls-0">On regarde votre zone, et je vous dis quoi faire.</h2>
              </div>

              <p class="mb-3">
                En 10 minutes, on clarifie : <strong>votre zone</strong>, <strong>vos prestations</strong>,
                et le type de demandes à viser (appels / devis).
              </p>

              <ul class="iconlist iconlist-color mb-4">
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Objectif</strong> : plus de demandes utiles</li>
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Filtre</strong> : zone / budget / délai</li>
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Plan</strong> : actions simples + priorités</li>
              </ul>

              <div class="d-flex flex-wrap gap-2">
                <a href="#zones" data-scrollto="#zones" class="button button-rounded button-light text-dark bg-white border text-transform-none ls-0">
                  Voir les zones
                </a>
                <a href="/faqs/" class="button button-rounded button-light text-dark bg-white border text-transform-none ls-0">
                  Questions fréquentes
                </a>
              </div>

              <small class="text-muted d-block mt-3">
                Sud Oise & Nord 95 — artisans, commerces, indépendants, TPE.
              </small>
            </div>

            <!-- Form Hubspot -->
            <div class="col-lg-4 col-md-5 mt-5 mt-md-0">
              <div class="card shadow-sm">
                <div class="card-body">
                  <h3 class="mb-2">Demander un audit</h3>
                  <p class="text-muted mb-3">Réponse rapide (jours ouvrés).</p>

                  <HubspotForm
                    context={{
                      page_type: "hub",
                      area: "Sud Oise / Nord 95",
                      page_url: "/seo-local-sud-oise-nord-95/",
                    }}
                  />

                  <small class="text-muted d-block mt-3">
                    Pas de spam. Juste un échange pour cadrer la zone et le besoin.
                  </small>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>

      <!-- Works/Projects (adapté HUB)
      ============================================= -->
      <div class="section m-0" style="background: url('/images/sections/5.jpg') no-repeat center center; background-size: cover; padding: 80px 0;">
        <div class="container">
          <div class="heading-block border-bottom-0 text-center">
            <div class="badge rounded-pill badge-default">Exemples concrets</div>
            <h2 class="text-transform-none ls-0">Ce qu’on met en place, selon votre zone</h2>
            <p class="text-muted mb-0">
              Chaque bassin a ses réalités (concurrence, rayon, types de demandes). Ici : des exemples simples, faits pour convertir.
            </p>
          </div>

          <div id="portfolio" class="portfolio row gutter-20">

            <!-- 1 : Nogent / Montataire -->
            <article class="portfolio-item col-12 col-sm-6 col-md-4">
              <div class="grid-inner">
                <div class="portfolio-image">
                  <img src="/images/works/1.jpg" alt="Nogent / Montataire : appels & devis">
                  <div class="bg-overlay">
                    <div class="bg-overlay-content dark" data-hover-animate="fadeIn" data-hover-speed="500">
                      <a href="/seo-local-sud-oise-nord-95/nogent-montataire/" class="overlay-trigger-icon bg-light text-dark" aria-label="Voir la page Nogent / Montataire" data-hover-animate="fadeIn" data-hover-speed="500">
                        <i class="uil uil-ellipsis-h"></i>
                      </a>
                    </div>
                    <div class="bg-overlay-bg dark" data-hover-animate="fadeIn" data-hover-speed="500"></div>
                  </div>
