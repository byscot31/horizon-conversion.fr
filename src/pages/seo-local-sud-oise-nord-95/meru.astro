---
import Layout from "../../layouts/Layout.astro";
import HubspotForm from "../../components/HubspotForm.astro";
import { SITE } from "../../config/site";

const pageUrl = Astro.url.pathname;
const cityLabel = "Méru";
const zoneLabel = "Sud de l’Oise & Nord Val-d’Oise (95)";

const pageTitle = `Consultant webmarketing ${cityLabel} | SEO local + Pub + Site (conversion)`;
const description = `${cityLabel} : visibilité locale sur Google + demandes qualifiées. SEO local + site clair + pub locale si besoin, avec filtrage (zone / besoin / délai).`;

const nearby = [
  "Andeville","Amblainville","Laboissière-en-Thelle","Belle-Église","Hénonville","Chambly",
  "Le Mesnil-en-Thelle","Persan","Beaumont-sur-Oise","L’Isle-Adam","Précy-sur-Oise",
  "Bornel","Auneuil","Gisors","Cires-lès-Mello","Mouy"
];

const quickFaqs = [
  {
    q: "Méru : pourquoi j’ai beaucoup de demandes “trop loin” ?",
    a: "Parce que Méru ouvre vite sur des zones très larges (Oise + 95 + parfois 27). On verrouille la zone (villes + rayon) et on écrit clairement les secteurs servis pour couper le hors-zone.",
  },
  {
    q: "SEO local à Méru : ça vaut le coup ?",
    a: "Oui si la page est <strong>spécifique</strong> (pas copiée) et reliée à ta fiche Google. Le but : apparaître localement et convertir (CTA + preuves + contact simple).",
  },
  {
    q: "Pub locale : comment éviter le gaspillage ?",
    a: "Ciblage serré + exclusions (zones trop loin) + annonces orientées “secteur servi”. On règle aussi le volume selon ta capacité (plein = on baisse / dispo = on relance).",
  },
  {
    q: "Je veux filtrer sans perdre des clients, possible ?",
    a: "Oui : 2–3 questions simples (ville, délai, besoin) + micro-copy rassurante. On filtre le hors sujet sans fermer la porte.",
  },
  {
    q: "Combien de temps avant de voir des résultats ?",
    a: "La pub peut démarrer vite. Le SEO met plus de temps mais dure. Dans tous les cas, on commence par un parcours simple qui convertit (CTA, preuve, contact).",
  },
  {
    q: "Tu bosses avec artisans / TPE autour de Méru ?",
    a: "Oui. Selon ton métier : urgence = appels, devis = formulaire, premium = rassurance + preuves + process.",
  },
];
---

<Layout title={pageTitle} description={description}>
  <!-- Page Title
  ============================================= -->
  <section
    class="page-title page-title-parallax parallax scroll-detect page-title-center dark include-header include-topbar"
    style="padding-bottom: 140px;"
  >
    <img
      src="/images/services/analysis-title.jpg"
      class="parallax-bg"
      alt="Méru : demandes locales qualifiées"
    />
    <div id="particles-line"></div>

    <div class="container position-relative">
      <div class="page-title-row">

        <div class="page-title-content">
          <div class="badge rounded-pill border border-light text-light">Zone : Méru & alentours</div>
          <h1>Méru : des demandes locales… sans le “trop loin”</h1>
          <div class="mt-3">
            <small class="text-light op-08 d-block">
              Zone étendue : on cadre le rayon (villes / distance) + filtrage (zone / besoin / délai) pour garder des demandes traitables.
            </small>
          </div>
        </div>

        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Accueil</a></li>
            <li class="breadcrumb-item"><a href="/seo-local-sud-oise-nord-95/">Sud Oise & Nord 95</a></li>
            <li class="breadcrumb-item active" aria-current="page">Méru</li>
          </ol>
        </nav>

      </div>
    </div>

    <div class="video-overlay z-1" style="background-image: linear-gradient(to top, rgba(254,150,3,0.5), #39384D);"></div>
  </section>

  <section id="content">
    <div class="content-wrap pb-0">

      <div class="container">

        <div class="row align-items-center">
          <div class="col-lg-7">
            <div class="badge rounded-pill badge-default">Méru</div>

            <h2 class="display-4 fw-bold">Plus de demandes, mais seulement dans ton rayon réel.</h2>

            <p>
              À Méru, on a souvent un effet “zone large” : les gens te contactent de loin (ou hors budget),
              parce que la zone n’est pas assez cadrée.
              Mon rôle : <strong>générer des demandes locales</strong> et <strong>filtrer le hors-zone</strong>.
            </p>

            <p class="mb-4">
              Concrètement : on définit ton <strong>rayon réaliste</strong> (villes / distance),
              on clarifie tes prestations (urgence, devis, projets), puis on met en place des pages locales + (si besoin) une pub locale.
              Ensuite, on suit l’essentiel : <strong>appels</strong>, <strong>formulaires</strong> et <strong>qualité</strong>.
            </p>

            <div class="d-flex flex-wrap gap-2">
              <a href="/contact/" class="button button-rounded button-large text-transform-none ls-0">Demander un audit</a>
              <a
                href="/seo-local-sud-oise-nord-95/"
                class="button button-rounded button-large button-light text-dark bg-white border text-transform-none ls-0"
              >
                Voir les autres zones
              </a>
              <a
                href="/faqs/"
                class="button button-rounded button-large button-light text-dark bg-white border text-transform-none ls-0"
              >
                FAQ
              </a>
            </div>

            <small class="text-muted d-block mt-3">
              Astuce : sur Méru, les exclusions (pub) + le texte “secteur servi” font une vraie différence sur la qualité.
            </small>

            <div class="mt-3">
              <small class="text-muted">
                Communes proches : {nearby.slice(0, 10).join(" • ")}…
              </small>
            </div>
          </div>

          <div class="col-lg-5 mt-4 mt-lg-0 text-center">
            <img
              src="/images/services/analysis.svg"
              alt="Cadrer la zone et filtrer les demandes à Méru"
              style="max-width: 420px;"
              loading="lazy"
            />
          </div>
        </div>

        <div class="clear line my-6"></div>

        <div class="heading-block border-bottom-0 text-center">
          <div class="badge rounded-pill badge-default">Ce que je mets en place</div>
          <h2 class="text-transform-none ls-0">Pour Méru : cadrage + filtrage + conversion</h2>
          <p class="text-muted mb-0" style="max-width: 780px; margin: 0 auto;">
            Ici, le but est de <strong>réduire le hors-zone</strong> tout en gardant du volume.
            On capte, on filtre, puis on transforme en appels/devis.
          </p>
        </div>

        <div class="clear"></div>

        <div class="row mt-4 col-mb-50 mb-0">

          <!-- 1 -->
          <div class="col-sm-6 col-lg-4">
            <div class="feature-box">
              <div class="fbox-icon mb-4">
                <a href="/seo-local-sud-oise-nord-95/meru/" aria-label="Pages locales Méru">
                  <i class="fa-brands fa-google text-white bg-google"></i>
                </a>
              </div>
              <div class="fbox-content">
                <h3 class="text-transform-none">Pages locales + Google (SEO local)</h3>
                <p class="mb-0">
                  Une page dédiée à Méru, avec <strong>secteurs servis</strong>, <strong>prestations</strong>,
                  preuves et CTA clairs pour déclencher des <strong>appels</strong> et des <strong>demandes de devis</strong>.
                </p>
                <small class="text-muted d-block mt-2">
                  Voir aussi : <a href="/seo-local-sud-oise-nord-95/">toutes les zones</a>
                </small>
              </div>
            </div>
          </div>

          <!-- 2 -->
          <div class="col-sm-6 col-lg-4">
            <div class="feature-box">
              <div class="fbox-icon mb-4">
                <a href="/faqs/" aria-label="Filtrage des demandes">
                  <i class="bi-funnel bg-dark border-0"></i>
                </a>
              </div>
              <div class="fbox-content">
                <h3 class="text-transform-none">Filtrage (anti “trop loin”)</h3>
                <p class="mb-0">
                  On filtre : <strong>hors zone</strong>, <strong>hors prestation</strong>, <strong>délai irréaliste</strong>, contact non joignable.
                  Objectif : moins de perte de temps, plus de demandes traitables.
                </p>
                <small class="text-muted d-block mt-2">
                  À lire : <a href="/faqs/">“demande qualifiée”, ça veut dire quoi ?</a>
                </small>
              </div>
            </div>
          </div>

          <!-- 3 -->
          <div class="col-sm-6 col-lg-4">
            <div class="feature-box">
              <div class="fbox-icon mb-4">
                <a href="/contact/" aria-label="Suivi des appels et formulaires">
                  <i class="bi-telephone bg-info border-0"></i>
                </a>
              </div>
              <div class="fbox-content">
                <h3 class="text-transform-none">Suivi simple (appels + formulaires)</h3>
                <p class="mb-0">
                  On suit l’essentiel : <strong>appels</strong>, <strong>formulaires</strong>, qualité.
                  Si vous êtes plein : on baisse. Si vous avez de la place : on relance.
                </p>
                <small class="text-muted d-block mt-2">
                  <a href="/contact/">Demander un audit</a> • réponse rapide (jours ouvrés)
                </small>
              </div>
            </div>
          </div>

        </div>

      </div>

      <div class="clear"></div>

      <!-- Zones autour / secteurs proches
      ============================================= -->
      <div class="section mb-0">
        <div class="container">
          <div class="heading-block border-bottom-0 text-center">
            <div class="badge rounded-pill badge-default">Zones autour</div>
            <h2 class="text-transform-none ls-0">Vous êtes proche de Méru ?</h2>
            <p class="text-muted mb-0" style="max-width: 820px; margin: 0 auto;">
              Choisissez la page la plus proche de votre secteur. Chaque bassin a son approche (volume, concurrence, type de demandes).
            </p>
          </div>

          <div class="row col-mb-30 align-content-stretch">

            <!-- 1 : Méru (page actuelle) -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/optimizing.svg" alt="Méru" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">Méru</h3>
                      <p class="text-smaller mb-0">
                        Zone étendue : on cadre fort le rayon et on filtre le hors-zone pour garder des demandes traitables.
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Méru • Andeville</li>
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Amblainville • Laboissière (selon rayon)</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : cadrage + tri</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 2 : Chambly -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/seo.svg" alt="Chambly" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/chambly/">Chambly</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Zone “connexion Oise / 95” : utile si tu veux un rayon plus ciblé autour de Chambly.
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Chambly • Bornel</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : demandes locales</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 3 : Nord 95 -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/adword.svg" alt="Nord 95" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/nord-95/">Nord 95</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Si ton activité “monte” dans le 95 : on choisit des villes fortes et on exclut le reste.
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Persan • Beaumont • L’Isle-Adam</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : ciblage serré</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 4 : Le Mesnil-en-Thelle -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/analysis.svg" alt="Le Mesnil-en-Thelle" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/le-mesnil-en-thelle/">Le Mesnil-en-Thelle</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Zone “proximité” : si tu veux concentrer autour du Thelle et éviter le trop large.
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Mesnil • Ste-Geneviève • alentours</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : local serré</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 5 : Creil / Saint-Maximin -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/analysis.svg" alt="Creil / Saint-Maximin" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/creil-saint-maximin/">Creil / Saint-Maximin</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Zone concurrentielle : volume + filtrage pour garder des demandes utiles.
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Creil • Saint-Maximin</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : volume + tri</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 6 : Hub (toutes les zones) -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/adword.svg" alt="Sud Oise & Nord 95" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/">Sud Oise & Nord 95 (hub)</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Accès rapide à toutes les pages zones + explications simples (SEO local, pub locale, conversion).
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Choisir la zone la plus proche</li>
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Comprendre l’approche par bassin</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> <a href="/contact/">Demander un audit</a></li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

          </div>

        </div>
      </div>

      <!-- Form Section (Méru)
      ============================================= -->
      <div
        class="section mt-0"
        style="background: url('/images/sections/1.jpg') no-repeat center center; background-size: cover; padding: 100px 0;"
      >
        <div class="container">
          <div class="row justify-content-between align-items-center">

            <!-- Texte -->
            <div class="col-md-6">
              <div class="heading-block border-bottom-0 mb-4">
                <div class="badge rounded-pill badge-default">Audit rapide</div>
                <h2 class="text-transform-none ls-0">Méru : on cadre le rayon, et on garde l’utile.</h2>
              </div>

              <p class="mb-3">
                Dans une zone “large”, le plus important c’est de recevoir des demandes <strong>exploitables</strong> :
                <strong>bonne zone</strong>, <strong>bonne prestation</strong>, <strong>délai réaliste</strong>, contact joignable.
                On verrouille le rayon et on filtre le hors-zone.
              </p>

              <ul class="iconlist iconlist-color mb-4">
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Zone</strong> : villes / rayon que vous traitez vraiment</li>
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Demandes</strong> : appels / formulaires / devis (selon activité)</li>
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Filtre</strong> : hors zone / hors budget / hors délai</li>
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Suivi</strong> : simple (on garde ce qui marche)</li>
              </ul>

              <div class="d-flex flex-wrap gap-2">
                <a href="/seo-local-sud-oise-nord-95/" class="button button-rounded button-light text-dark bg-white border text-transform-none ls-0">
                  Voir toutes les zones
                </a>
                <a href="/faqs/" class="button button-rounded button-light text-dark bg-white border text-transform-none ls-0">
                  FAQ (réponses simples)
                </a>
              </div>

              <small class="text-muted d-block mt-3">
                Tu es plus “connexion 95” ?{" "}
                <a href="/seo-local-sud-oise-nord-95/nord-95/">Nord 95</a>
                {" "}•{" "}
                Zone locale serrée ?{" "}
                <a href="/seo-local-sud-oise-nord-95/le-mesnil-en-thelle/">Le Mesnil-en-Thelle</a>
              </small>
            </div>

            <!-- Form HubSpot -->
            <div class="col-lg-4 col-md-5 mt-5 mt-md-0">
              <div class="card shadow-sm">
                <div class="card-body">
                  <h3 class="mb-2">Demander un audit</h3>
                  <p class="text-muted mb-3">Réponse rapide (jours ouvrés).</p>

                  <HubspotForm
                    context={{
                      page_type: "zone",
                      zone: "Méru",
                      area: "Sud Oise / Nord 95",
                      page_url: Astro.url.pathname,
                    }}
                  />

                  <small class="text-muted d-block mt-3">
                    Pas de spam. Un échange pour cadrer la zone + le type de demandes à viser.
                  </small>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>

      <!-- FAQ express -->
      <div class="section bg-transparent mt-0" style="background: url('/images/sections/3.jpg') no-repeat top center; background-size: cover; padding: 0 0 70px;">
        <div class="container">
          <div class="heading-block border-bottom-0 text-center">
            <div class="badge rounded-pill badge-default">FAQ express</div>
            <h2 class="text-transform-none ls-0">Questions fréquentes (Méru)</h2>
            <p class="text-muted mb-0">
              Zone étendue : on filtre le “trop loin” et on garde des demandes traitables. Réponses courtes.
            </p>
          </div>

          <div class="row justify-content-center">
            <div class="col-lg-10">
              {quickFaqs.map((item) => (
                <div class="toggle faq pb-3 mb-4">
                  <div class="toggle-header">
                    <div class="toggle-icon color">
                      <i class="toggle-closed bi-question-circle"></i>
                      <i class="toggle-open bi-question-circle"></i>
                    </div>
                    <div class="toggle-title fw-semibold ps-1">{item.q}</div>
                    <div class="toggle-icon color">
                      <i class="toggle-closed fa-solid fa-chevron-down text-black-50"></i>
                      <i class="toggle-open fa-solid fa-chevron-up color"></i>
                    </div>
                  </div>

                  <div class="toggle-content text-black-50 ps-4">
                    {item.a}

                    <div class="mt-2">
                      <small class="text-muted">
                        Besoin d’une reco rapide ?{" "}
                        <a href="/contact/">Demander un audit</a>
                        {" "}•{" "}
                        <a href="/seo-local-sud-oise-nord-95/">Voir toutes les zones</a>
                        {" "}•{" "}
                        Zones proches :{" "}
                        <a href="/seo-local-sud-oise-nord-95/chambly/">Chambly</a>
                        {" "}•{" "}
                        <a href="/seo-local-sud-oise-nord-95/nord-95/">Nord 95</a>
                      </small>
                    </div>
                  </div>
                </div>
              ))}

              <div class="text-center d-flex flex-wrap justify-content-center gap-2">
                <a href="/faqs/" class="button button-rounded text-transform-none ls-0">Voir toutes les FAQ</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Promo/Contact (Méru)
      ============================================= -->
      <div
        class="section mt-5"
        style="padding: 100px 0; overflow: visible; background: url('/images/sections/3.jpg') no-repeat top center; background-size: cover;"
      >
        <div class="container">
          <div class="heading-block border-bottom-0 text-center">
            <div class="h5 text-uppercase ls-1 mb-2">Méru • Andeville • Amblainville</div>

            <h2 class="text-transform-none ls-0 mb-3">
              Vous voulez plus <span>d’appels</span> et de <span>demandes de devis</span>…
              <br class="d-none d-md-block" />
              sans recevoir des demandes “trop loin” ?
            </h2>

            <p class="text-muted mb-0" style="max-width: 820px; margin: 0 auto;">
              On fait un point rapide : votre rayon réel, vos prestations, et le type de demandes à viser.
              Ensuite je te dis si le plus pertinent est <strong>SEO local</strong>, <strong>pub locale</strong>, ou un <strong>mix</strong>
              (avec filtrage).
