---
import Layout from "../../layouts/Layout.astro";
import HubspotForm from "../../components/HubspotForm.astro";
import { SITE } from "../../config/site";

const pageUrl = Astro.url.pathname;
const cityLabel = "Le Mesnil-en-Thelle";
const zoneLabel = "Sud de l’Oise & Nord Val-d’Oise (95)";

const pageTitle = `Consultant webmarketing ${cityLabel} | SEO local + Pub locale + Site (conversion)`;
const description = `${cityLabel} : visibilité locale sur Google + site clair + (option) pub locale pour générer des demandes qualifiées.`;

const nearby = [
  "Le Mesnil-en-Thelle","Chambly","Bornel","Méru","Andeville","Amblainville","Cires-lès-Mello",
  "Mello","Précy-sur-Oise","Saint-Leu-d’Esserent","Persan","Beaumont-sur-Oise","L’Isle-Adam",
  "Creil","Nogent-sur-Oise","Montataire","Chantilly","Senlis"
];

const quickFaqs = [
  {
    q: "Le Mesnil-en-Thelle : c’est plutôt “proximité” ?",
    a: "Oui : l’idée c’est de capter des demandes proches (rayon réaliste) et d’avoir un site qui convertit vite : CTA visibles, preuves, contact simple.",
  },
  {
    q: "Comment éviter les demandes trop loin ?",
    a: "On annonce clairement les secteurs servis (villes + rayon), on ajoute du filtrage (ville / délai), et en pub on exclut les zones éloignées.",
  },
  {
    q: "SEO local ou pub locale ici ?",
    a: "Le SEO local marche très bien en proximité. La pub est utile si tu veux accélérer ponctuellement (quand tu as de la place).",
  },
  {
    q: "Je veux surtout des appels, pas des formulaires interminables",
    a: "Parfait : on met un parcours “appel” propre (click-to-call, CTA fixes, sections courtes) et un formulaire court pour les demandes de devis.",
  },
  {
    q: "Combien de temps avant de voir des résultats ?",
    a: "La pub peut démarrer vite. Le SEO met plus de temps mais dure. Dans tous les cas, on commence par une page claire qui convertit.",
  },
  {
    q: "Tu bosses avec artisans / TPE autour ?",
    a: "Oui, et on adapte : dépannage = appels, devis = formulaire, projets = rassurance + process.",
  },
];
---

<Layout title={pageTitle} description={description}>
  <!-- Page Title
  ============================================= -->
  <section
    class="page-title page-title-parallax parallax scroll-detect page-title-center dark include-header include-topbar"
    style="padding-bottom: 140px;"
  >
    <img
      src="/images/services/analysis-title.jpg"
      class="parallax-bg"
      alt="Le Mesnil-en-Thelle : SEO local et demandes qualifiées"
    />
    <div id="particles-line"></div>

    <div class="container position-relative">
      <div class="page-title-row">

        <div class="page-title-content">
          <div class="badge rounded-pill border border-light text-light">Zone : Proximité Sud Oise</div>
          <h1>Le Mesnil-en-Thelle : des demandes locales, simples et efficaces</h1>
          <div class="mt-3">
            <small class="text-light op-08 d-block">
              Proximité : on clarifie la zone, on rend le site évident, et on transforme en appels/devis (sans bruit).
            </small>
          </div>
        </div>

        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Accueil</a></li>
            <li class="breadcrumb-item"><a href="/seo-local-sud-oise-nord-95/">Sud Oise & Nord 95</a></li>
            <li class="breadcrumb-item active" aria-current="page">Le Mesnil-en-Thelle</li>
          </ol>
        </nav>

      </div>
    </div>

    <div class="video-overlay z-1" style="background-image: linear-gradient(to top, rgba(254,150,3,0.5), #39384D);"></div>
  </section>

  <section id="content">
    <div class="content-wrap pb-0">

      <div class="container">

        <div class="row align-items-center">
          <div class="col-lg-7">
            <div class="badge rounded-pill badge-default">{cityLabel}</div>

            <h2 class="display-4 fw-bold">Proximité : site clair → appels + devis, sans complication.</h2>

            <p>
              Sur Le Mesnil-en-Thelle et autour, on peut gagner vite avec un message simple :
              <strong>zone</strong> + <strong>prestations</strong> + <strong>contact facile</strong>.
              Mon rôle : te ramener des <strong>demandes locales</strong> et éviter le hors-sujet.
            </p>

            <p class="mb-4">
              Concrètement : on définit ton <strong>rayon réel</strong>, on renforce la présence Google (SEO local),
              et si tu veux accélérer, on ajoute une <strong>pub locale</strong> bien cadrée.
              Ensuite, on suit l’essentiel : <strong>appels</strong>, <strong>formulaires</strong>, et la qualité.
            </p>

            <div class="d-flex flex-wrap gap-2">
              <a href="/contact/" class="button button-rounded button-large text-transform-none ls-0">Demander un audit</a>
              <a
                href="/seo-local-sud-oise-nord-95/"
                class="button button-rounded button-large button-light text-dark bg-white border text-transform-none ls-0"
              >
                Voir les autres zones
              </a>
              <a
                href="/faqs/"
                class="button button-rounded button-large button-light text-dark bg-white border text-transform-none ls-0"
              >
                FAQ
              </a>
            </div>

            <small class="text-muted d-block mt-3">
              Astuce : en proximité, un bon SEO local + une page claire convertit souvent mieux qu’un “site vitrine” trop long.
            </small>

            <div class="mt-3">
              <small class="text-muted">
                Communes proches : {nearby.slice(0, 10).join(" • ")}…
              </small>
            </div>
          </div>

          <div class="col-lg-5 mt-4 mt-lg-0 text-center">
            <img
              src="/images/services/analysis.svg"
              alt="Conversion locale Le Mesnil-en-Thelle"
              style="max-width: 420px;"
              loading="lazy"
            />
          </div>
        </div>

        <div class="clear line my-6"></div>

        <div class="heading-block border-bottom-0 text-center">
          <div class="badge rounded-pill badge-default">Ce que je mets en place</div>
          <h2 class="text-transform-none ls-0">Pour Le Mesnil-en-Thelle : proximité, clarté, conversion</h2>
          <p class="text-muted mb-0" style="max-width: 780px; margin: 0 auto;">
            Ici, on cherche des <strong>demandes proches</strong> et faciles à traiter : appels / devis, pas du hors-zone.
          </p>
        </div>

        <div class="clear"></div>

        <div class="row mt-4 col-mb-50 mb-0">

          <!-- 1 -->
          <div class="col-sm-6 col-lg-4">
            <div class="feature-box">
              <div class="fbox-icon mb-4">
                <a href="/seo-local-sud-oise-nord-95/le-mesnil-en-thelle/" aria-label="SEO local Le Mesnil-en-Thelle">
                  <i class="fa-brands fa-google text-white bg-google"></i>
                </a>
              </div>
              <div class="fbox-content">
                <h3 class="text-transform-none">SEO local + Google</h3>
                <p class="mb-0">
                  Page locale propre + cohérence Google (zone, services, preuves) pour déclencher des
                  <strong> appels</strong> et <strong>devis</strong>.
                </p>
                <small class="text-muted d-block mt-2">
                  Voir aussi : <a href="/seo-local-sud-oise-nord-95/">toutes les zones</a>
                </small>
              </div>
            </div>
          </div>

          <!-- 2 -->
          <div class="col-sm-6 col-lg-4">
            <div class="feature-box">
              <div class="fbox-icon mb-4">
                <a href="/faqs/" aria-label="Filtrage des demandes">
                  <i class="bi-funnel bg-dark border-0"></i>
                </a>
              </div>
              <div class="fbox-content">
                <h3 class="text-transform-none">Filtrage léger (anti hors-zone)</h3>
                <p class="mb-0">
                  2–3 questions simples (ville, délai, besoin) pour limiter le hors-sujet
                  sans freiner les bons clients.
                </p>
                <small class="text-muted d-block mt-2">
                  À lire : <a href="/faqs/">“demande qualifiée”, ça veut dire quoi ?</a>
                </small>
              </div>
            </div>
          </div>

          <!-- 3 -->
          <div class="col-sm-6 col-lg-4">
            <div class="feature-box">
              <div class="fbox-icon mb-4">
                <a href="/contact/" aria-label="Suivi appels et formulaires">
                  <i class="bi-telephone bg-info border-0"></i>
                </a>
              </div>
              <div class="fbox-content">
                <h3 class="text-transform-none">Conversion + suivi</h3>
                <p class="mb-0">
                  CTA visibles, contact simple, et suivi des <strong>appels</strong>/<strong>formulaires</strong>.
                  On ajuste selon ta capacité (plein = on baisse).
                </p>
                <small class="text-muted d-block mt-2">
                  <a href="/contact/">Demander un audit</a> • réponse rapide (jours ouvrés)
                </small>
              </div>
            </div>
          </div>

        </div>

      </div>

      <div class="clear"></div>

      <!-- Zones autour / secteurs proches
      ============================================= -->
      <div class="section mb-0">
        <div class="container">
          <div class="heading-block border-bottom-0 text-center">
            <div class="badge rounded-pill badge-default">Zones autour</div>
            <h2 class="text-transform-none ls-0">Vous êtes proche du Mesnil-en-Thelle ?</h2>
            <p class="text-muted mb-0" style="max-width: 820px; margin: 0 auto;">
              Choisissez la page la plus proche de votre secteur. Chaque bassin a son approche.
            </p>
          </div>

          <div class="row col-mb-30 align-content-stretch">

            <!-- 1 : Le Mesnil-en-Thelle (page actuelle) -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/optimizing.svg" alt="Le Mesnil-en-Thelle" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">Le Mesnil-en-Thelle</h3>
                      <p class="text-smaller mb-0">
                        Proximité : demandes locales + conversion simple (appels/devis), sans complexité.
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Mesnil-en-Thelle • Bornel</li>
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Cires-lès-Mello (selon rayon)</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : proximité</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 2 : Chambly -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/seo.svg" alt="Chambly" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/chambly/">Chambly</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Zone charnière Oise/95 : rayon clair + filtrage pour éviter le hors-zone.
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Chambly • Bornel</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : rayon + tri</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 3 : Méru -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/optimizing.svg" alt="Méru" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/meru/">Méru</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Zone étendue : on cadre le rayon et on filtre fort pour éviter les demandes trop loin.
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Méru • Andeville</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : SEO + tri</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 4 : Nord 95 -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/adword.svg" alt="Nord 95" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/nord-95/">Nord 95</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Persan • Beaumont • L’Isle-Adam : ciblage + exclusions pour garder du qualifié.
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Persan • Beaumont</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : ciblage</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 5 : Creil / Saint-Maximin -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/analysis.svg" alt="Creil / Saint-Maximin" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/creil-saint-maximin/">Creil / Saint-Maximin</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Zone concurrentielle : volume + tri (appels/devis) pour couper le bruit.
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Creil • Saint-Maximin</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> Approche : volume + filtre</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- 6 : Hub -->
            <div class="col-lg-4 col-md-6 d-flex">
              <div class="card w-100">
                <div class="card-body p-5">
                  <div class="feature-box flex-column">
                    <div class="fbox-icon mb-3">
                      <img src="/images/icons/adword.svg" alt="Sud Oise & Nord 95" class="bg-transparent rounded-0">
                    </div>
                    <div class="fbox-content">
                      <h3 class="text-transform-none ls-0 text-larger">
                        <a class="nav-link d-inline" href="/seo-local-sud-oise-nord-95/">Sud Oise & Nord 95 (hub)</a>
                      </h3>
                      <p class="text-smaller mb-0">
                        Accès rapide à toutes les pages zones + explications simples (SEO local, pub locale, conversion).
                      </p>
                    </div>
                    <ul class="iconlist ms-3 mt-4 mb-0">
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Choisir la zone la plus proche</li>
                      <li class="mb-2 text-muted"><i class="fa-solid fa-check text-smaller color"></i> Comprendre l’approche par bassin</li>
                      <li class="text-muted"><i class="fa-solid fa-check text-smaller color"></i> <a href="/contact/">Demander un audit</a></li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

          </div>

        </div>
      </div>

      <!-- Form Section (Le Mesnil-en-Thelle)
      ============================================= -->
      <div
        class="section mt-0"
        style="background: url('/images/sections/1.jpg') no-repeat center center; background-size: cover; padding: 100px 0;"
      >
        <div class="container">
          <div class="row justify-content-between align-items-center">

            <!-- Texte -->
            <div class="col-md-6">
              <div class="heading-block border-bottom-0 mb-4">
                <div class="badge rounded-pill badge-default">Audit rapide</div>
                <h2 class="text-transform-none ls-0">Le Mesnil-en-Thelle : simple, local, efficace.</h2>
              </div>

              <p class="mb-3">
                L’objectif : des demandes <strong>proches</strong> et <strong>exploitables</strong>.
                On cadre la zone, on clarifie le message, et on optimise le contact (appels/devis).
              </p>

              <ul class="iconlist iconlist-color mb-4">
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Zone</strong> : villes / rayon réel</li>
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Contact</strong> : appels + formulaire court</li>
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Filtre</strong> : hors zone / hors délai</li>
                <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Suivi</strong> : on garde ce qui marche</li>
              </ul>

              <div class="d-flex flex-wrap gap-2">
                <a href="/seo-local-sud-oise-nord-95/" class="button button-rounded button-light text-dark bg-white border text-transform-none ls-0">
                  Voir toutes les zones
                </a>
                <a href="/faqs/" class="button button-rounded button-light text-dark bg-white border text-transform-none ls-0">
                  FAQ (réponses simples)
                </a>
              </div>

              <small class="text-muted d-block mt-3">
                Zone charnière Oise/95 ?{" "}
                <a href="/seo-local-sud-oise-nord-95/chambly/">Chambly</a>
                {" "}•{" "}
                Plutôt 95 ?{" "}
                <a href="/seo-local-sud-oise-nord-95/nord-95/">Nord 95</a>
              </small>
            </div>

            <!-- Form HubSpot -->
            <div class="col-lg-4 col-md-5 mt-5 mt-md-0">
              <div class="card shadow-sm">
                <div class="card-body">
                  <h3 class="mb-2">Demander un audit</h3>
                  <p class="text-muted mb-3">Réponse rapide (jours ouvrés).</p>

                  <HubspotForm
                    context={{
                      page_type: "zone",
                      zone: "Le Mesnil-en-Thelle",
                      area: "Sud Oise / Nord 95",
                      page_url: Astro.url.pathname,
                    }}
                  />

                  <small class="text-muted d-block mt-3">
                    Pas de spam. Un échange pour cadrer la zone + le type de demandes à viser.
                  </small>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>

      <!-- FAQ express -->
      <div class="section bg-transparent mt-0" style="background: url('/images/sections/3.jpg') no-repeat top center; background-size: cover; padding: 0 0 70px;">
        <div class="container">
          <div class="heading-block border-bottom-0 text-center">
            <div class="badge rounded-pill badge-default">FAQ express</div>
            <h2 class="text-transform-none ls-0">Questions fréquentes (Le Mesnil-en-Thelle)</h2>
            <p class="text-muted mb-0">
              Proximité : on vise des demandes proches et simples à traiter. Réponses courtes.
            </p>
          </div>

          <div class="row justify-content-center">
            <div class="col-lg-10">
              {quickFaqs.map((item) => (
                <div class="toggle faq pb-3 mb-4">
                  <div class="toggle-header">
                    <div class="toggle-icon color">
                      <i class="toggle-closed bi-question-circle"></i>
                      <i class="toggle-open bi-question-circle"></i>
                    </div>
                    <div class="toggle-title fw-semibold ps-1">{item.q}</div>
                    <div class="toggle-icon color">
                      <i class="toggle-closed fa-solid fa-chevron-down text-black-50"></i>
                      <i class="toggle-open fa-solid fa-chevron-up color"></i>
                    </div>
                  </div>

                  <div class="toggle-content text-black-50 ps-4">
                    {item.a}

                    <div class="mt-2">
                      <small class="text-muted">
                        Besoin d’une reco rapide ?{" "}
                        <a href="/contact/">Demander un audit</a>
                        {" "}•{" "}
                        <a href="/seo-local-sud-oise-nord-95/">Voir toutes les zones</a>
                        {" "}•{" "}
                        Zones proches :{" "}
                        <a href="/seo-local-sud-oise-nord-95/chambly/">Chambly</a>
                        {" "}•{" "}
                        <a href="/seo-local-sud-oise-nord-95/meru/">Méru</a>
                      </small>
                    </div>
                  </div>
                </div>
              ))}

              <div class="text-center d-flex flex-wrap justify-content-center gap-2">
                <a href="/faqs/" class="button button-rounded text-transform-none ls-0">Voir toutes les FAQ</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Promo/Contact (Le Mesnil-en-Thelle)
      ============================================= -->
      <div
        class="section mt-5"
        style="padding: 100px 0; overflow: visible; background: url('/images/sections/3.jpg') no-repeat top center; background-size: cover;"
      >
        <div class="container">
          <div class="heading-block border-bottom-0 text-center">
            <div class="h5 text-uppercase ls-1 mb-2">Le Mesnil-en-Thelle • Sud Oise</div>

            <h2 class="text-transform-none ls-0 mb-3">
              Vous voulez plus <span>d’appels</span> et de <span>demandes de devis</span>…
              <br class="d-none d-md-block" />
              en restant sur votre secteur ?
            </h2>

            <p class="text-muted mb-0" style="max-width: 820px; margin: 0 auto;">
              On fait un point rapide : votre zone réelle, vos prestations, et le type de demandes à viser.
              Ensuite je te dis si le plus pertinent est <strong>SEO local</strong>, <strong>pub locale</strong>, ou un <strong>mix</strong>
              (avec filtrage).
            </p>

            <div class="d-flex flex-wrap justify-content-center gap-2 mt-4">
              <a href="/contact/" class="button button-large button-rounded text-transform-none ms-0 ls-0">
                Demander un audit
              </a>

              <a
                href="/seo-local-sud-oise-nord-95/"
                class="button button-large button-rounded button-light text-dark bg-white border text-transform-none ls-0"
              >
                Voir toutes les zones
              </a>

              <a
                href="/faqs/"
                class="button button-large button-rounded button-light text-dark bg-white border text-transform-none ls-0"
              >
                FAQ
              </a>
            </div>

            <small class="text-muted d-block mt-3">
              Zones proches :{" "}
