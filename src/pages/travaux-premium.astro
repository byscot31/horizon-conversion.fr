---
import Layout from "../layouts/Layout.astro";
import HubspotForm from "../components/HubspotForm.astro";
import { METIERS, ZONE } from "../data/catalogue";
import { SITE } from "../components/config/site";

const pageTitle = `Travaux premium – demandes qualifiées pour artisans (${ZONE})`;
const description =
  `Des demandes qualifiées orientées travaux (rénovation, remplacement, chantiers planifiés) dans le ${ZONE}. ` +
  `Paiement uniquement quand c’est qualifié.`;

const HUBSPOT_PORTAL_ID = import.meta.env.PUBLIC_HUBSPOT_PORTAL_ID ?? "PORTAL_ID";
const HUBSPOT_FORM_ID = import.meta.env.PUBLIC_HUBSPOT_FORM_ID ?? "FORM_ID";

// Mini liste métiers (liens “money”)
const metierOrder = ["plombier", "electricien", "chauffagiste", "couvreur", "menuisier", "serrurier"];
const metiers = metierOrder
  .map((slug) => METIERS.find((m) => m.slug === slug))
  .filter(Boolean);
---

<Layout title={pageTitle} description={description}>
  <section class="page-title page-title-parallax parallax scroll-detect page-title-center dark include-header include-topbar">
    <img src="/images/hero/hero-1.jpg" class="parallax-bg" alt="" />
    <div id="particles-line"></div>

    <div class="container">
      <div class="page-title-row">
        <div class="page-title-content">
          <div class="badge rounded-pill border border-light text-light">Travaux premium</div>
          <h1>Des demandes orientées rénovation et chantiers planifiés</h1>
        </div>

        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Accueil</a></li>
            <li class="breadcrumb-item active" aria-current="page">Travaux premium</li>
          </ol>
        </nav>
      </div>
    </div>

    <div class="video-overlay z-1" style="background-image: linear-gradient(to top, rgba(254,150,3,0.5), #39384D);"></div>
  </section>

  <section id="content">
    <div class="content-wrap pb-0">
      <div class="container">

        <div class="row align-items-center">
          <div class="col-lg-7">
            <div class="badge rounded-pill badge-default">{ZONE}</div>
            <h2 class="display-4 fw-bold">Idéal si vous voulez moins d’urgence, plus de “vrais” chantiers.</h2>

            <p>
              Ici, on vise surtout des demandes type : rénovation, remplacement complet, projets planifiés.
              Toujours le même principe : <strong>paiement uniquement quand c’est qualifié</strong>.
            </p>

            <ul class="iconlist iconlist-color mb-4">
              <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Projet</strong> : travaux clairs (pas “je réfléchis”)</li>
              <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Budget / délai</strong> : cohérents</li>
              <li class="d-block"><i class="bi-check-circle-fill"></i><strong>Contact</strong> : joignable</li>
            </ul>

            <a href="/contact/" class="button button-rounded button-large text-transform-none ls-0">Recevoir des demandes</a>
            <a href={`tel:${SITE.phoneE164}`} class="button button-rounded button-large button-light text-dark bg-white border text-transform-none ls-0">
              Appeler : {SITE.phoneDisplay}
            </a>

            <div class="mt-4 text-muted">
              <small>Vous faites plutôt du dépannage / urgence ? Retour à la page <a href="/">Accueil</a>.</small>
            </div>
          </div>

          <div class="col-lg-5 mt-4 mt-lg-0">
            <img src="/images/services/adwords.svg" alt="" />
          </div>
        </div>

        <div class="clear line my-6"></div>

        <div class="heading-block border-bottom-0 text-center">
          <div class="badge rounded-pill badge-default">Métiers</div>
          <h3 class="text-transform-none ls-0">Pages utiles</h3>
          <p class="mb-0 text-muted">Accès direct à tes pages money.</p>
        </div>

        <div class="row col-mb-30 mt-4">
          {metiers.map((m) => (
            <div class="col-md-6 col-lg-4">
              <a class="card h-shadow h-translate-y-sm all-ts text-decoration-none" href={`/metiers/${m.slug}/`}>
                <div class="card-body p-5">
                  <h3 class="text-transform-none ls-0 mb-0">{m.name}</h3>
                  <p class="text-smaller text-muted mb-0">Services + villes (maillage local)</p>
                </div>
              </a>
            </div>
          ))}
        </div>

      </div>

      <div
        class="section mt-6"
        style="background: url('/images/sections/1.jpg') no-repeat center center; background-size: cover; padding: 100px 0;"
      >
        <div class="container">
          <div class="row justify-content-between align-items-center">

            <div class="col-lg-6 col-md-6">
              <div class="heading-block border-bottom-0 mb-4">
                <div class="badge rounded-pill badge-default">Recevoir des demandes</div>
                <h3 class="text-transform-none ls-0">
                  Vous voulez des demandes “travaux” ?
                  <br />Laissez vos infos, je vous explique le fonctionnement.
                </h3>
              </div>
              <p class="mb-0">Zone : {ZONE}. Objectif : demandes plus planifiées (rénovation / remplacement / chantiers).</p>
            </div>

            <div class="col-lg-4 col-md-5 mt-5 mt-md-0">
              <div class="card shadow-sm">
                <div class="card-body">
                  <h4 class="mb-3">Recevoir des demandes</h4>
                  <HubspotForm portalId={HUBSPOT_PORTAL_ID} formId={HUBSPOT_FORM_ID} />
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>
